{
  "pipeline_type": "rna-seq-de",
  "description": "Bulk RNA-seq differential expression pipeline using Salmon for transcript quantification and tximeta for importing counts into DESeq2.",
  "tools": [
    {
      "name": "fastqc",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and trimmed reads to assess read quality metrics",
      "language": "CLI"
    },
    {
      "name": "trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "salmon",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/salmon",
        "tag": "1.10.0--h7e5ed60_0",
        "full_uri": "quay.io/biocontainers/salmon:1.10.0--h7e5ed60_0",
        "source": "biocontainers"
      },
      "purpose": "Quasi-mapping-based transcript-level quantification from trimmed reads",
      "language": "CLI"
    },
    {
      "name": "tximeta",
      "version": "1.18.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-tximeta",
        "tag": "1.18.0--r42hdfd78af_0",
        "full_uri": "quay.io/biocontainers/bioconductor-tximeta:1.18.0--r42hdfd78af_0",
        "source": "biocontainers"
      },
      "purpose": "Import Salmon quant.sf files into R with transcript metadata and offset-aware count matrices",
      "language": "R"
    },
    {
      "name": "deseq2",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Differential expression analysis on tximeta-imported count matrices",
      "language": "R"
    },
    {
      "name": "clusterprofiler",
      "version": "3.6.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-clusterprofiler",
        "tag": "3.6.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-clusterprofiler:3.6.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "GO and KEGG pathway enrichment analysis on DEG results",
      "language": "R"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate QC logs from FastQC, Trimmomatic, and Salmon into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "fastqc",
      "input": [
        "data/raw/{sample}_R1.fastq.gz",
        "data/raw/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/raw_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/raw_fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "trimmomatic",
      "input": [
        "data/raw/{sample}_R1.fastq.gz",
        "data/raw/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "fastqc",
      "input": [
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz"
      ],
      "output": [
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_paired_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_paired_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/post_trim_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/post_trim_fastqc/{sample}.log"
      ]
    },
    {
      "name": "salmon_quant",
      "tool": "salmon",
      "input": [
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz"
      ],
      "output": [
        "salmon/{sample}/quant.sf",
        "salmon/{sample}/lib_format_counts.json"
      ],
      "params": {
        "index": "resources/salmon_index",
        "libtype": "A",
        "threads": 8,
        "outdir": "salmon/{sample}",
        "strandedness": "{config[strandedness]}",
        "paired_end": "{config[paired_end]}"
      },
      "shell_cmd": "salmon quant --index {params.index} --libType {params.libtype} -1 {input[0]} -2 {input[1]} --threads {params.threads} --validateMappings --gcBias --seqBias --output {params.outdir} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/salmon/{sample}.log"
      ]
    },
    {
      "name": "tximeta_import",
      "tool": "tximeta",
      "input": [
        "salmon_quant_dirs.txt"
      ],
      "output": [
        "tximeta/se_object.rds"
      ],
      "params": {
        "sample_sheet": "config/sample_sheet.csv",
        "organism": "{config[organism]}",
        "genome_build": "{config[genome_build]}",
        "ensembl_release": "{config[ensembl_release]}"
      },
      "shell_cmd": "Rscript scripts/tximeta_import.R --quant_dirs {input[0]} --sample_sheet {params.sample_sheet} --organism {params.organism} --genome_build {params.genome_build} --ensembl_release {params.ensembl_release} --output {output[0]} 2> {log[0]}",
      "script": "scripts/tximeta_import.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/tximeta/tximeta_import.log"
      ]
    },
    {
      "name": "differential_expr",
      "tool": "deseq2",
      "input": [
        "tximeta/se_object.rds"
      ],
      "output": [
        "results/deseq2/dds_object.rds",
        "results/deseq2/de_results.csv",
        "results/deseq2/normalized_counts.csv",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/volcano_plot.pdf",
        "results/deseq2/ma_plot.pdf"
      ],
      "params": {
        "condition_col": "{config[condition_col]}",
        "reference_level": "{config[reference_level]}",
        "lfc_threshold": "{config[lfc_threshold]}",
        "fdr_threshold": "{config[fdr_threshold]}"
      },
      "shell_cmd": "Rscript scripts/run_deseq2.R --se_object {input[0]} --condition_col {params.condition_col} --reference_level {params.reference_level} --lfc_threshold {params.lfc_threshold} --fdr_threshold {params.fdr_threshold} --outdir results/deseq2 2> {log[0]}",
      "script": "scripts/run_deseq2.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 10000
      },
      "log": [
        "logs/deseq2/differential_expr.log"
      ]
    },
    {
      "name": "go_enrichment",
      "tool": "clusterprofiler",
      "input": [
        "results/deseq2/de_results.csv"
      ],
      "output": [
        "results/enrichment/go_bp_results.csv",
        "results/enrichment/go_mf_results.csv",
        "results/enrichment/go_cc_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf"
      ],
      "params": {
        "organism_db": "{config[organism_db]}",
        "kegg_organism": "{config[kegg_organism]}",
        "fdr_threshold": "{config[fdr_threshold]}",
        "lfc_threshold": "{config[lfc_threshold]}",
        "pvalue_cutoff": 0.05,
        "qvalue_cutoff": 0.2
      },
      "shell_cmd": "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --fdr_threshold {params.fdr_threshold} --lfc_threshold {params.lfc_threshold} --pvalue_cutoff {params.pvalue_cutoff} --qvalue_cutoff {params.qvalue_cutoff} --outdir results/enrichment 2> {log[0]}",
      "script": "scripts/run_clusterprofiler.R",
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/clusterprofiler/go_enrichment.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "multiqc",
      "input": [
        "qc/raw_fastqc",
        "qc/post_trim_fastqc",
        "logs/trimmomatic",
        "salmon",
        "results/deseq2"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "title": "RNA-seq QC Report"
      },
      "shell_cmd": "multiqc {input[0]} {input[1]} {input[2]} {input[3]} {input[4]} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc_report.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "post_trim_fastqc"
    ],
    [
      "trim_reads",
      "salmon_quant"
    ],
    [
      "salmon_quant",
      "tximeta_import"
    ],
    [
      "tximeta_import",
      "differential_expr"
    ],
    [
      "differential_expr",
      "go_enrichment"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "salmon_quant",
      "multiqc_report"
    ],
    [
      "differential_expr",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "S1",
      "S2",
      "S3"
    ],
    "paired_end": true,
    "strandedness": 0,
    "salmon_index": "resources/salmon_index",
    "adapters": "resources/adapters.fa",
    "organism": "Homo sapiens",
    "genome_build": "GRCh38",
    "ensembl_release": 109,
    "organism_db": "org.Hs.eg.db",
    "kegg_organism": "hsa",
    "condition_col": "condition",
    "reference_level": "control",
    "lfc_threshold": 1.0,
    "fdr_threshold": 0.05,
    "sample_sheet": "config/sample_sheet.csv"
  },
  "wildcards": [
    "sample"
  ]
}