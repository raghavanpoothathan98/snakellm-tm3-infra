{
  "pipeline_type": "atac-seq",
  "description": "ATAC-seq chromatin accessibility pipeline using Bowtie2 alignment, deepTools QC, and MACS2 peak calling to identify open chromatin regions.",
  "tools": [
    {
      "name": "fastqc",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw FASTQ reads",
      "language": "CLI"
    },
    {
      "name": "trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming using Nextera adapters specific to ATAC-seq",
      "language": "CLI"
    },
    {
      "name": "bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Alignment of trimmed reads to reference genome",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped, low MAPQ, and mitochondrial reads; sort and index BAM files",
      "language": "CLI"
    },
    {
      "name": "picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Remove PCR duplicates via MarkDuplicates",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads for Tn5 bias correction and generate bigWig coverage tracks",
      "language": "CLI"
    },
    {
      "name": "macs2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Peak calling to identify open chromatin regions",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq specific QC metrics including TSS enrichment and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "bioconductor-chipseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate peaks to nearest genomic features such as promoters and enhancers",
      "language": "R"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC reports into a single HTML summary report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "fastqc",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "config[nextera_adapters]",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 20,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "index": "config[bowtie2_index]",
        "threads": 8,
        "maxins": 2000
      },
      "shell_cmd": "bowtie2 -p {params.threads} -X {params.maxins} --very-sensitive -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "chrM": "config[mito_chr]"
      },
      "shell_cmd": "samtools view -b -F 1804 -f 2 -q {params.mapq} -@ {params.threads} {input[0]} | samtools view -b $(samtools idxstats {input[0]} | cut -f1 | grep -v '{params.chrM}' | tr '\\n' ' ') -o {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 30000
      },
      "log": [
        "logs/samtools_filter/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "dedup/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g",
        "validation_stringency": "LENIENT",
        "remove_duplicates": "true"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai"
      ],
      "output": [
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
      ],
      "params": {
        "threads": 4,
        "atac_shift": "--ATACshift"
      },
      "shell_cmd": "alignmentSieve -b {input[0]} -o {output[0]} --numberOfProcessors {params.threads} {params.atac_shift} 2> {log[0]} && samtools sort -o {output[0]}.tmp {output[0]} && mv {output[0]}.tmp {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/deeptools_sieve/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "macs2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_peaks.xls",
        "peaks/{sample}_summits.bed"
      ],
      "params": {
        "outdir": "peaks",
        "genome_size": "config[macs2_genome_size]",
        "qvalue": 0.05,
        "shift": -100,
        "extsize": 200,
        "format": "BAM"
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -f {params.format} -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup all --call-summits 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "qc/ataqv/{sample}.ataqv.json",
        "qc/ataqv/{sample}.ataqv.txt"
      ],
      "params": {
        "organism": "config[organism]",
        "tss_file": "config[tss_bed]"
      },
      "shell_cmd": "ataqv --tss-file {params.tss_file} --peak-file {input[1]} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
      ],
      "output": [
        "bigwig/{sample}.bw"
      ],
      "params": {
        "threads": 4,
        "binsize": 10,
        "normalize": "RPKM",
        "effective_genome_size": "config[effective_genome_size]"
      },
      "shell_cmd": "bamCoverage -b {input[0]} -o {output[0]} --binSize {params.binsize} --normalizeUsing {params.normalize} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/bamcoverage/{sample}.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "bioconductor-chipseeker",
      "input": [
        "peaks/all_samples_peaks_merged.narrowPeak"
      ],
      "output": [
        "annotation/peaks_annotation.csv",
        "annotation/peaks_annotation_summary.pdf"
      ],
      "params": {
        "txdb": "config[txdb]",
        "organism_db": "config[organism_db]",
        "tss_region_start": -3000,
        "tss_region_end": 3000
      },
      "shell_cmd": "Rscript scripts/chipseeker_annotate.R {input[0]} {output[0]} {output[1]} {params.txdb} {params.organism_db} {params.tss_region_start} {params.tss_region_end} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/annotate_peaks.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "multiqc",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "logs/bowtie2",
        "dedup",
        "qc/ataqv",
        "bigwig",
        "annotation"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "config": "config[multiqc_config]"
      },
      "shell_cmd": "multiqc qc/fastqc logs/trimmomatic logs/bowtie2 dedup qc/ataqv bigwig annotation --outdir {params.outdir} --config {params.config} --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "shift_reads",
      "peak_qc"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "call_peaks",
      "annotate_peaks"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "create_bigwig",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3"
    ],
    "paired_end": true,
    "strandedness": 0,
    "bowtie2_index": "resources/genome/hg38",
    "nextera_adapters": "resources/adapters/NexteraPE-PE.fa",
    "mito_chr": "chrM",
    "macs2_genome_size": "hs",
    "organism": "human",
    "tss_bed": "resources/hg38_tss.bed",
    "txdb": "TxDb.Hsapiens.UCSC.hg38.knownGene",
    "organism_db": "org.Hs.eg.db",
    "effective_genome_size": 2700000000,
    "genome_build": "hg38",
    "multiqc_config": "config/multiqc_config.yaml"
  },
  "wildcards": [
    "sample"
  ]
}