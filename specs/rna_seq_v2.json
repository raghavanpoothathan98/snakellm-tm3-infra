{
  "pipeline_type": "rna-seq-de",
  "description": "Bulk RNA-seq differential expression analysis pipeline using STAR alignment, featureCounts quantification, and DESeq2 for identifying differentially expressed genes.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and trimmed reads to assess read quality metrics",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "STAR",
      "version": "2.7.10a",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/star",
        "tag": "2.7.10a--h9ee0642_1",
        "full_uri": "quay.io/biocontainers/star:2.7.10a--h9ee0642_1",
        "source": "biocontainers"
      },
      "purpose": "Splice-aware alignment of trimmed reads to reference genome",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "1.17",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "1.17--h00cdaf9_0",
        "full_uri": "quay.io/biocontainers/samtools:1.17--h00cdaf9_0",
        "source": "biocontainers"
      },
      "purpose": "Sort and index aligned BAM files for downstream processing",
      "language": "CLI"
    },
    {
      "name": "featureCounts",
      "version": "1.5.0p3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/subread",
        "tag": "1.5.0p3--0",
        "full_uri": "quay.io/biocontainers/subread:1.5.0p3--0",
        "source": "biocontainers"
      },
      "purpose": "Gene-level read quantification to generate count matrix",
      "language": "CLI"
    },
    {
      "name": "DESeq2",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Differential expression analysis, generating results table, MA plot, and PCA",
      "language": "R"
    },
    {
      "name": "clusterProfiler",
      "version": "3.6.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-clusterprofiler",
        "tag": "3.6.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-clusterprofiler:3.6.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "GO and KEGG pathway enrichment analysis on differentially expressed genes",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC logs into a single HTML summary report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/raw/{sample}_R1_fastqc.html",
        "qc/raw/{sample}_R1_fastqc.zip",
        "qc/raw/{sample}_R2_fastqc.html",
        "qc/raw/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/raw",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/raw/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "FastQC",
      "input": [
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz"
      ],
      "output": [
        "qc/trimmed/{sample}_R1_trimmed_fastqc.html",
        "qc/trimmed/{sample}_R1_trimmed_fastqc.zip",
        "qc/trimmed/{sample}_R2_trimmed_fastqc.html",
        "qc/trimmed/{sample}_R2_trimmed_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/trimmed",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/trimmed/{sample}.log"
      ]
    },
    {
      "name": "align_star",
      "tool": "STAR",
      "input": [
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz"
      ],
      "output": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out"
      ],
      "params": {
        "genome_dir": "resources/star_index",
        "threads": 8,
        "outdir_prefix": "aligned/{sample}/"
      },
      "shell_cmd": "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} --runMode alignReads 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/star/{sample}.log"
      ]
    },
    {
      "name": "sort_index_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
      ],
      "output": [
        "aligned/{sample}/{sample}.sorted.bam",
        "aligned/{sample}/{sample}.sorted.bam.bai"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} && samtools index {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/samtools/{sample}.log"
      ]
    },
    {
      "name": "featurecounts",
      "tool": "featureCounts",
      "input": [
        "aligned/S1/S1.sorted.bam",
        "aligned/S2/S2.sorted.bam",
        "aligned/S3/S3.sorted.bam",
        "aligned/S4/S4.sorted.bam",
        "aligned/S5/S5.sorted.bam",
        "aligned/S6/S6.sorted.bam"
      ],
      "output": [
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary"
      ],
      "params": {
        "gtf": "resources/annotation.gtf",
        "threads": 8,
        "strandedness": "{config[strandedness]}",
        "paired_end_flag": "{config[paired_end]}"
      },
      "shell_cmd": "featureCounts -T {params.threads} -s {params.strandedness} $(if [ \"{params.paired_end_flag}\" = \"True\" ]; then echo \"-p\"; fi) -a {params.gtf} -o {output[0]} {input}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/featurecounts/featurecounts.log"
      ]
    },
    {
      "name": "differential_expr",
      "tool": "DESeq2",
      "input": [
        "counts/all_samples_counts.txt"
      ],
      "output": [
        "results/deseq2/diff_expr_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv"
      ],
      "params": {
        "sample_info": "resources/sample_info.csv",
        "condition_col": "condition",
        "reference_level": "control",
        "lfc_threshold": 1.0,
        "padj_threshold": 0.05
      },
      "shell_cmd": "Rscript scripts/run_deseq2.R --counts {input[0]} --sample_info {params.sample_info} --condition_col {params.condition_col} --reference_level {params.reference_level} --lfc_threshold {params.lfc_threshold} --padj_threshold {params.padj_threshold} --results_out {output[0]} --ma_plot {output[1]} --pca_plot {output[2]} --norm_counts {output[3]} 2> {log[0]}",
      "script": "scripts/run_deseq2.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 10000
      },
      "log": [
        "logs/deseq2/deseq2.log"
      ]
    },
    {
      "name": "go_enrichment",
      "tool": "clusterProfiler",
      "input": [
        "results/deseq2/diff_expr_results.csv"
      ],
      "output": [
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf"
      ],
      "params": {
        "organism_db": "org.Hs.eg.db",
        "kegg_organism": "hsa",
        "padj_threshold": 0.05,
        "lfc_threshold": 1.0
      },
      "shell_cmd": "Rscript scripts/run_clusterprofiler.R --deseq2_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --go_out {output[0]} --kegg_out {output[1]} --go_plot {output[2]} --kegg_plot {output[3]} 2> {log[0]}",
      "script": "scripts/run_clusterprofiler.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/clusterprofiler/enrichment.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/raw",
        "qc/trimmed",
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/diff_expr_results.csv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "search_dirs": "qc/raw qc/trimmed logs/star logs/featurecounts"
      },
      "shell_cmd": "multiqc {params.search_dirs} logs/star logs/trimmomatic logs/featurecounts --outdir {params.outdir} --filename multiqc_report.html 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "post_trim_fastqc"
    ],
    [
      "trim_reads",
      "align_star"
    ],
    [
      "align_star",
      "sort_index_bam"
    ],
    [
      "sort_index_bam",
      "featurecounts"
    ],
    [
      "featurecounts",
      "differential_expr"
    ],
    [
      "differential_expr",
      "go_enrichment"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "featurecounts",
      "multiqc_report"
    ],
    [
      "differential_expr",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "S1",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6"
    ],
    "strandedness": 2,
    "paired_end": true,
    "genome_dir": "resources/star_index",
    "gtf": "resources/annotation.gtf",
    "adapters": "resources/adapters.fa",
    "sample_info": "resources/sample_info.csv",
    "condition_col": "condition",
    "reference_level": "control",
    "lfc_threshold": 1.0,
    "padj_threshold": 0.05,
    "organism_db": "org.Hs.eg.db",
    "kegg_organism": "hsa",
    "genome_build": "hg38"
  },
  "wildcards": [
    "sample"
  ]
}