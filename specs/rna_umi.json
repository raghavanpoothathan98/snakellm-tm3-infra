{
  "pipeline_type": "rna-seq-de-umi",
  "description": "Bulk RNA-seq differential expression pipeline with UMI-based deduplication using UMI-tools prior to gene-level quantification with featureCounts.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and UMI-extracted reads to assess base quality, adapter content, and duplication levels",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming and quality-based read trimming while preserving UMI sequences",
      "language": "CLI"
    },
    {
      "name": "UMItools",
      "version": "1.1.4",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Extract UMI sequences from read headers and deduplicate alignments based on mapping position and UMI",
      "language": "CLI"
    },
    {
      "name": "STAR",
      "version": "2.5.4a",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/star",
        "tag": "2.5.4a--0",
        "full_uri": "quay.io/biocontainers/star:2.5.4a--0",
        "source": "biocontainers"
      },
      "purpose": "Splice-aware alignment of UMI-extracted trimmed reads to reference genome producing coordinate-sorted BAM",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Sort and index BAM files to prepare for UMI-tools deduplication",
      "language": "CLI"
    },
    {
      "name": "subread",
      "version": "1.5.0p3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/subread",
        "tag": "1.5.0p3--0",
        "full_uri": "quay.io/biocontainers/subread:1.5.0p3--0",
        "source": "biocontainers"
      },
      "purpose": "Gene-level read quantification on deduplicated BAM files to build count matrix",
      "language": "CLI"
    },
    {
      "name": "DESeq2",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Differential expression analysis on UMI-deduplicated count matrix with MA plot and PCA",
      "language": "R"
    },
    {
      "name": "clusterProfiler",
      "version": "3.6.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-clusterprofiler",
        "tag": "3.6.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-clusterprofiler:3.6.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "GO and KEGG pathway enrichment analysis on differentially expressed genes",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate QC metrics from all steps into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/raw_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/raw_fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "sliding_window": "4:15",
        "min_len": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "umi_extract",
      "tool": "UMItools",
      "input": [
        "trimmed/{sample}_R1_trimmed.fastq.gz",
        "trimmed/{sample}_R2_trimmed.fastq.gz"
      ],
      "output": [
        "umi_extracted/{sample}_R1_umi.fastq.gz",
        "umi_extracted/{sample}_R2_umi.fastq.gz"
      ],
      "params": {
        "bc_pattern": "NNNNNNNN",
        "log_file": "logs/umi_extract/{sample}_extract.log"
      },
      "shell_cmd": "umi_tools extract --bc-pattern={params.bc_pattern} --stdin={input[0]} --read2-in={input[1]} --stdout={output[0]} --read2-out={output[1]} --log={params.log_file} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/umi_extract/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "FastQC",
      "input": [
        "umi_extracted/{sample}_R1_umi.fastq.gz",
        "umi_extracted/{sample}_R2_umi.fastq.gz"
      ],
      "output": [
        "qc/post_trim_fastqc/{sample}_R1_umi_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_umi_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_umi_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_umi_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/post_trim_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/post_trim_fastqc/{sample}.log"
      ]
    },
    {
      "name": "align_star",
      "tool": "STAR",
      "input": [
        "umi_extracted/{sample}_R1_umi.fastq.gz",
        "umi_extracted/{sample}_R2_umi.fastq.gz"
      ],
      "output": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out"
      ],
      "params": {
        "genome_dir": "resources/star_index",
        "threads": 8,
        "outdir_prefix": "aligned/{sample}/"
      },
      "shell_cmd": "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} --outSAMunmapped Within > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 180,
        "disk_mb": 60000
      },
      "log": [
        "logs/star/{sample}.log"
      ]
    },
    {
      "name": "sort_index_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
      ],
      "output": [
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} > {log[0]} 2>&1 && samtools index {output[0]} >> {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 30000
      },
      "log": [
        "logs/samtools/{sample}.log"
      ]
    },
    {
      "name": "umi_dedup",
      "tool": "UMItools",
      "input": [
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai"
      ],
      "output": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai"
      ],
      "params": {
        "method": "directional",
        "log_file": "logs/umi_dedup/{sample}_dedup.log"
      },
      "shell_cmd": "umi_tools dedup --method={params.method} --paired -I {input[0]} -S {output[0]} --log={params.log_file} > {log[0]} 2>&1 && samtools index {output[0]} >> {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/umi_dedup/{sample}.log"
      ]
    },
    {
      "name": "featurecounts",
      "tool": "subread",
      "input": [
        "dedup/S1.dedup.bam",
        "dedup/S2.dedup.bam",
        "dedup/S3.dedup.bam"
      ],
      "output": [
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary"
      ],
      "params": {
        "gtf": "resources/annotation.gtf",
        "threads": 8,
        "strandedness": "{config[strandedness]}",
        "paired_end_flag": "{config[paired_end]}"
      },
      "shell_cmd": "featureCounts -T {params.threads} -s {params.strandedness} $(if [ \"{params.paired_end_flag}\" = \"True\" ]; then echo \"-p\"; fi) -a {params.gtf} -o {output[0]} {input} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/featurecounts/featurecounts.log"
      ]
    },
    {
      "name": "differential_expr",
      "tool": "DESeq2",
      "input": [
        "counts/all_samples_counts.txt"
      ],
      "output": [
        "results/deseq2/diff_expr_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv"
      ],
      "params": {
        "condition_col": "condition",
        "ref_level": "control",
        "padj_threshold": 0.05,
        "lfc_threshold": 1.0,
        "organism_db": "org.Hs.eg.db"
      },
      "shell_cmd": "Rscript scripts/run_deseq2.R --counts {input[0]} --out_results {output[0]} --out_ma {output[1]} --out_pca {output[2]} --out_norm {output[3]} --condition_col {params.condition_col} --ref_level {params.ref_level} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --organism_db {params.organism_db} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/deseq2/deseq2.log"
      ]
    },
    {
      "name": "go_enrichment",
      "tool": "clusterProfiler",
      "input": [
        "results/deseq2/diff_expr_results.csv"
      ],
      "output": [
        "results/enrichment/go_enrichment_results.csv",
        "results/enrichment/kegg_enrichment_results.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf"
      ],
      "params": {
        "organism_db": "org.Hs.eg.db",
        "kegg_organism": "hsa",
        "padj_threshold": 0.05,
        "lfc_threshold": 1.0,
        "ont": "BP"
      },
      "shell_cmd": "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --ont {params.ont} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/clusterprofiler/go_enrichment.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/raw_fastqc",
        "qc/post_trim_fastqc",
        "logs/trimmomatic",
        "logs/umi_extract",
        "aligned",
        "logs/umi_dedup",
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/diff_expr_results.csv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "dirs": "qc/raw_fastqc qc/post_trim_fastqc logs/trimmomatic logs/umi_extract aligned logs/umi_dedup counts results/deseq2"
      },
      "shell_cmd": "multiqc {params.dirs} --outdir {params.outdir} --force > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "umi_extract"
    ],
    [
      "umi_extract",
      "post_trim_fastqc"
    ],
    [
      "umi_extract",
      "align_star"
    ],
    [
      "align_star",
      "sort_index_bam"
    ],
    [
      "sort_index_bam",
      "umi_dedup"
    ],
    [
      "umi_dedup",
      "featurecounts"
    ],
    [
      "featurecounts",
      "differential_expr"
    ],
    [
      "differential_expr",
      "go_enrichment"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "align_star",
      "multiqc_report"
    ],
    [
      "umi_dedup",
      "multiqc_report"
    ],
    [
      "featurecounts",
      "multiqc_report"
    ],
    [
      "differential_expr",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "S1",
      "S2",
      "S3"
    ],
    "strandedness": 0,
    "paired_end": true,
    "genome_dir": "resources/star_index",
    "gtf": "resources/annotation.gtf",
    "adapters": "resources/adapters.fa",
    "umi_bc_pattern": "NNNNNNNN",
    "umi_dedup_method": "directional",
    "condition_col": "condition",
    "ref_level": "control",
    "padj_threshold": 0.05,
    "lfc_threshold": 1.0,
    "organism_db": "org.Hs.eg.db",
    "kegg_organism": "hsa",
    "go_ontology": "BP",
    "min_read_len": 36
  },
  "wildcards": [
    "sample"
  ]
}