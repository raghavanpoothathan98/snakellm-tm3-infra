{
  "pipeline_type": "rna-seq-de",
  "description": "Bulk RNA-seq differential expression analysis in mouse liver using edgeR for identifying differentially expressed genes.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and trimmed reads to assess read quality metrics",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "STAR",
      "version": "2.5.4a",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/star",
        "tag": "2.5.4a--0",
        "full_uri": "quay.io/biocontainers/star:2.5.4a--0",
        "source": "biocontainers"
      },
      "purpose": "Splice-aware alignment of trimmed reads to mouse reference genome (mm10)",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Sort and index aligned BAM files for downstream quantification",
      "language": "CLI"
    },
    {
      "name": "featureCounts",
      "version": "1.5.0p3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/subread",
        "tag": "1.5.0p3--0",
        "full_uri": "quay.io/biocontainers/subread:1.5.0p3--0",
        "source": "biocontainers"
      },
      "purpose": "Gene-level read quantification against mouse GTF annotation",
      "language": "CLI"
    },
    {
      "name": "edgeR",
      "version": "3.24.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-edger",
        "tag": "3.24.1--r351hf484d3e_0",
        "full_uri": "quay.io/biocontainers/bioconductor-edger:3.24.1--r351hf484d3e_0",
        "source": "biocontainers"
      },
      "purpose": "Differential expression analysis on count matrix with edgeR",
      "language": "R"
    },
    {
      "name": "clusterProfiler",
      "version": "3.6.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-clusterprofiler",
        "tag": "3.6.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-clusterprofiler:3.6.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "GO and KEGG pathway enrichment analysis on DE genes",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC logs into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/raw_fastqc/{sample}_R1_fastqc.html",
        "qc/raw_fastqc/{sample}_R1_fastqc.zip",
        "qc/raw_fastqc/{sample}_R2_fastqc.html",
        "qc/raw_fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/raw_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/raw_fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "FastQC",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/post_trim_fastqc/{sample}_R1_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R1_fastqc.zip",
        "qc/post_trim_fastqc/{sample}_R2_fastqc.html",
        "qc/post_trim_fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/post_trim_fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/post_trim_fastqc/{sample}.log"
      ]
    },
    {
      "name": "align_star",
      "tool": "STAR",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam",
        "aligned/{sample}/Log.final.out"
      ],
      "params": {
        "genome_dir": "resources/star_genome_mm10",
        "threads": 8,
        "outdir_prefix": "aligned/{sample}/"
      },
      "shell_cmd": "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --outFileNamePrefix {params.outdir_prefix} --outSAMunmapped Within --runMode alignReads 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 180,
        "disk_mb": 60000
      },
      "log": [
        "logs/star/{sample}.log"
      ]
    },
    {
      "name": "sort_index_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam"
      ],
      "output": [
        "aligned/{sample}/Aligned.sortedByCoord.out.bam.bai"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "samtools index -@ {params.threads} {input[0]} {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/samtools/{sample}.log"
      ]
    },
    {
      "name": "featurecounts",
      "tool": "featureCounts",
      "input": [
        "aligned/S1/Aligned.sortedByCoord.out.bam",
        "aligned/S2/Aligned.sortedByCoord.out.bam",
        "aligned/S3/Aligned.sortedByCoord.out.bam",
        "aligned/S4/Aligned.sortedByCoord.out.bam",
        "aligned/S5/Aligned.sortedByCoord.out.bam",
        "aligned/S6/Aligned.sortedByCoord.out.bam"
      ],
      "output": [
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary"
      ],
      "params": {
        "gtf": "resources/annotation/mm10.gtf",
        "threads": 8,
        "strandedness": "{config[strandedness]}",
        "paired_end_flag": "{config[paired_end]}"
      },
      "shell_cmd": "featureCounts -T {params.threads} -s {params.strandedness} $(if [ \"{params.paired_end_flag}\" = \"True\" ]; then echo \"-p\"; fi) -a {params.gtf} -o {output[0]} {input} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/featurecounts/featurecounts.log"
      ]
    },
    {
      "name": "differential_expr",
      "tool": "edgeR",
      "input": [
        "counts/all_samples_counts.txt"
      ],
      "output": [
        "results/edgeR/de_results.csv",
        "results/edgeR/de_sig_genes.csv",
        "results/edgeR/ma_plot.pdf",
        "results/edgeR/volcano_plot.pdf"
      ],
      "params": {
        "fdr_threshold": 0.05,
        "logfc_threshold": 1.0,
        "sample_metadata": "resources/sample_metadata.csv",
        "condition_column": "condition",
        "reference_level": "control"
      },
      "shell_cmd": "Rscript scripts/run_edgeR.R --counts {input[0]} --metadata {params.sample_metadata} --condition_col {params.condition_column} --reference {params.reference_level} --fdr {params.fdr_threshold} --logfc {params.logfc_threshold} --out_de {output[0]} --out_sig {output[1]} --out_ma {output[2]} --out_volcano {output[3]} 2> {log[0]}",
      "script": "scripts/run_edgeR.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/edgeR/differential_expr.log"
      ]
    },
    {
      "name": "go_enrichment",
      "tool": "clusterProfiler",
      "input": [
        "results/edgeR/de_sig_genes.csv"
      ],
      "output": [
        "results/enrichment/go_bp_results.csv",
        "results/enrichment/go_mf_results.csv",
        "results/enrichment/kegg_results.csv",
        "results/enrichment/go_bp_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf"
      ],
      "params": {
        "organism_db": "org.Mm.eg.db",
        "kegg_organism": "mmu",
        "pvalue_cutoff": 0.05,
        "qvalue_cutoff": 0.2,
        "gene_id_type": "ENSEMBL"
      },
      "shell_cmd": "Rscript scripts/run_clusterProfiler.R --de_genes {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --pvalue_cutoff {params.pvalue_cutoff} --qvalue_cutoff {params.qvalue_cutoff} --gene_id_type {params.gene_id_type} --out_go_bp {output[0]} --out_go_mf {output[1]} --out_kegg {output[2]} --out_go_bp_plot {output[3]} --out_kegg_plot {output[4]} 2> {log[0]}",
      "script": "scripts/run_clusterProfiler.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/clusterProfiler/go_enrichment.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/raw_fastqc",
        "qc/post_trim_fastqc",
        "logs/trimmomatic",
        "aligned",
        "counts/all_samples_counts.txt.summary",
        "results/edgeR/de_results.csv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "title": "Mouse Liver RNA-seq QC Report"
      },
      "shell_cmd": "multiqc --force --title \"{params.title}\" --outdir {params.outdir} qc/raw_fastqc qc/post_trim_fastqc logs/trimmomatic aligned counts results/edgeR 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "post_trim_fastqc"
    ],
    [
      "trim_reads",
      "align_star"
    ],
    [
      "align_star",
      "sort_index_bam"
    ],
    [
      "sort_index_bam",
      "featurecounts"
    ],
    [
      "featurecounts",
      "differential_expr"
    ],
    [
      "differential_expr",
      "go_enrichment"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "align_star",
      "multiqc_report"
    ],
    [
      "featurecounts",
      "multiqc_report"
    ],
    [
      "differential_expr",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "S1",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6"
    ],
    "strandedness": 2,
    "paired_end": true,
    "genome_build": "mm10",
    "star_genome_dir": "resources/star_genome_mm10",
    "gtf": "resources/annotation/mm10.gtf",
    "adapters": "resources/adapters.fa",
    "sample_metadata": "resources/sample_metadata.csv",
    "condition_column": "condition",
    "reference_level": "control",
    "fdr_threshold": 0.05,
    "logfc_threshold": 1.0,
    "organism_db": "org.Mm.eg.db",
    "kegg_organism": "mmu",
    "gene_id_type": "ENSEMBL",
    "pvalue_cutoff": 0.05,
    "qvalue_cutoff": 0.2
  },
  "wildcards": [
    "sample"
  ]
}