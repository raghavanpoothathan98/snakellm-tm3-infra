{
  "pipeline_type": "atac-seq",
  "description": "ATAC-seq chromatin accessibility pipeline with MACS2 peak calling and IDR reproducibility filtering across biological replicates.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw ATAC-seq reads",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming using Nextera adapter sequences",
      "language": "CLI"
    },
    {
      "name": "Bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Short-read alignment to reference genome (splice-unaware, appropriate for ATAC-seq)",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped, low MAPQ (<30), and mitochondrial reads from BAM",
      "language": "CLI"
    },
    {
      "name": "Picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Mark and remove PCR duplicates with MarkDuplicates",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads +4/-5 bp for Tn5 transposase bias correction (alignmentSieve) and generate bigWig tracks (bamCoverage)",
      "language": "CLI"
    },
    {
      "name": "MACS2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks using --nomodel --shift -100 --extsize 200 per replicate",
      "language": "CLI"
    },
    {
      "name": "IDR",
      "version": "2.0.3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/idr",
        "tag": "2.0.3--py36_0",
        "full_uri": "quay.io/biocontainers/idr:2.0.3--py36_0",
        "source": "biocontainers"
      },
      "purpose": "Irreproducibility Discovery Rate filtering to select reproducible peaks across biological replicates",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq specific QC metrics including TSS enrichment score and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "ChIPseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate peaks to nearest gene, promoter, or enhancer regions",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC reports into a single HTML summary report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "config[nextera_adapters]",
        "leading": 3,
        "trailing": 3,
        "sliding_window": "4:15",
        "min_len": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.sliding_window} MINLEN:{params.min_len} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "Bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "index": "config[bowtie2_index]",
        "threads": 8,
        "max_fragment_size": 2000,
        "extra": "--very-sensitive"
      },
      "shell_cmd": "bowtie2 -p {params.threads} -x {params.index} -X {params.max_fragment_size} {params.extra} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} - && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "blacklist_chroms": "chrM"
      },
      "shell_cmd": "samtools view -h -b -q {params.mapq} -F 1804 -f 2 {input[0]} | samtools view -b $(samtools view -H {input[0]} | grep '^@SQ' | grep -v '{params.blacklist_chroms}' | awk '{{gsub(\"SN:\",\"\",$2); printf $2\" \"}}') -o {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 30000
      },
      "log": [
        "logs/samtools_filter/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "Picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g",
        "remove_duplicates": "true",
        "validation_stringency": "LENIENT"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 120,
        "disk_mb": 40000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.deduped.bam"
      ],
      "output": [
        "shifted/{sample}.shifted.bam"
      ],
      "params": {
        "threads": 8,
        "shift_plus": 4,
        "shift_minus": -5,
        "ATACshift": "--ATACshift"
      },
      "shell_cmd": "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} --outFile {output[0]} 2> {log[0]} && samtools sort -o {output[0]}.sorted.bam {output[0]} && mv {output[0]}.sorted.bam {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/deeptools_shift/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "MACS2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls"
      ],
      "params": {
        "outdir": "peaks",
        "genome_size": "config[macs2_genome_size]",
        "nomodel": "--nomodel",
        "shift": -100,
        "extsize": 200,
        "qvalue": 0.05,
        "keep_dup": "all",
        "call_summits": "--call-summits"
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -n {wildcards.sample} --outdir {params.outdir} -g {params.genome_size} {params.nomodel} --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup {params.keep_dup} {params.call_summits} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "bigwig/{sample}.bw"
      ],
      "params": {
        "threads": 8,
        "bin_size": 10,
        "normalize_using": "RPGC",
        "effective_genome_size": "config[effective_genome_size]",
        "extra": "--extendReads"
      },
      "shell_cmd": "bamCoverage --numberOfProcessors {params.threads} --bam {input[0]} --outFileName {output[0]} --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} {params.extra} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/bamcoverage/{sample}.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "qc/ataqv/{sample}.ataqv.json.gz",
        "qc/ataqv/{sample}.ataqv.out"
      ],
      "params": {
        "tss_file": "config[tss_bed]",
        "organism": "config[organism]",
        "excluded_region_file": "config[blacklist_bed]"
      },
      "shell_cmd": "ataqv --tss-file {params.tss_file} --excluded-region-file {params.excluded_region_file} --metrics-file {output[0]} {params.organism} {input[0]} --peak-file {input[1]} > {output[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "idr_filter",
      "tool": "IDR",
      "input": [
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak"
      ],
      "output": [
        "idr/{rep1}_vs_{rep2}_idr_peaks.txt",
        "idr/{rep1}_vs_{rep2}_idr_peaks.narrowPeak"
      ],
      "params": {
        "idr_threshold": 0.05,
        "rank": "signal.value",
        "soft_idr_threshold": 0.1,
        "plot": "--plot"
      },
      "shell_cmd": "idr --samples {input[0]} {input[1]} --input-file-type narrowPeak --rank {params.rank} --output-file {output[0]} --soft-idr-threshold {params.soft_idr_threshold} --idr-threshold {params.idr_threshold} {params.plot} --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\\t\"}} $12 >= -log(0.05)/log(10) {{print $0}}' {output[0]} > {output[1]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/idr/{rep1}_vs_{rep2}.log"
      ]
    },
    {
      "name": "motif_analysis",
      "tool": "ChIPseeker",
      "input": [
        "idr/all_idr_peaks.narrowPeak"
      ],
      "output": [
        "motifs/motif_enrichment.txt",
        "motifs/motif_enrichment.html"
      ],
      "params": {
        "genome": "config[genome_build]",
        "motif_db": "config[homer_motif_db]",
        "size": 200,
        "threads": 8
      },
      "shell_cmd": "findMotifsGenome.pl {input[0]} {params.genome} motifs/ -size {params.size} -p {params.threads} -mknown {params.motif_db} 2> {log[0]} && cp motifs/knownResults.html {output[1]} && cp motifs/knownResults.txt {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 180,
        "disk_mb": 20000
      },
      "log": [
        "logs/motif_analysis/motif_analysis.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "ChIPseeker",
      "input": [
        "idr/all_idr_peaks.narrowPeak"
      ],
      "output": [
        "annotation/peak_annotation.tsv",
        "annotation/peak_annotation_plots.pdf"
      ],
      "params": {
        "genome_build": "config[genome_build]",
        "txdb": "config[txdb_package]",
        "org_db": "config[org_db]",
        "promoter_upstream": 3000,
        "promoter_downstream": 3000
      },
      "shell_cmd": "Rscript scripts/annotate_peaks.R --peaks {input[0]} --genome {params.genome_build} --txdb {params.txdb} --org_db {params.org_db} --upstream {params.promoter_upstream} --downstream {params.promoter_downstream} --output_table {output[0]} --output_plots {output[1]} 2> {log[0]}",
      "script": "scripts/annotate_peaks.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/annotate_peaks.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "logs/bowtie2",
        "deduped",
        "qc/ataqv",
        "motifs/knownResults.txt",
        "annotation/peak_annotation.tsv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "dirs": "qc/fastqc logs/trimmomatic logs/bowtie2 deduped qc/ataqv"
      },
      "shell_cmd": "multiqc {params.dirs} --outdir {params.outdir} --filename multiqc_report.html --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "shift_reads",
      "peak_qc"
    ],
    [
      "call_peaks",
      "idr_filter"
    ],
    [
      "idr_filter",
      "motif_analysis"
    ],
    [
      "idr_filter",
      "annotate_peaks"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "create_bigwig",
      "multiqc_report"
    ],
    [
      "motif_analysis",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1_rep1",
      "sample1_rep2",
      "sample2_rep1",
      "sample2_rep2"
    ],
    "replicates": {
      "condition1": [
        "sample1_rep1",
        "sample1_rep2"
      ],
      "condition2": [
        "sample2_rep1",
        "sample2_rep2"
      ]
    },
    "idr_pairs": [
      [
        "sample1_rep1",
        "sample1_rep2"
      ],
      [
        "sample2_rep1",
        "sample2_rep2"
      ]
    ],
    "paired_end": true,
    "strandedness": 0,
    "genome_build": "hg38",
    "bowtie2_index": "resources/bowtie2_index/hg38",
    "nextera_adapters": "resources/NexteraPE-PE.fa",
    "macs2_genome_size": "hs",
    "effective_genome_size": 2747877777,
    "tss_bed": "resources/hg38_tss.bed",
    "blacklist_bed": "resources/hg38_blacklist.bed",
    "organism": "human",
    "txdb_package": "TxDb.Hsapiens.UCSC.hg38.knownGene",
    "org_db": "org.Hs.eg.db",
    "homer_motif_db": "resources/HOCOMOCOv11_core_HUMAN_mono_meme_format.meme",
    "mapq_threshold": 30,
    "idr_threshold": 0.05,
    "macs2_qvalue": 0.05,
    "macs2_shift": -100,
    "macs2_extsize": 200
  },
  "wildcards": [
    "sample",
    "rep1",
    "rep2"
  ]
}