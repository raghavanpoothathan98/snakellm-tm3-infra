{
  "pipeline_type": "atac-seq",
  "description": "ATAC-seq chromatin accessibility analysis with MACS2 peak calling and IDR filtering for reproducible peak identification across biological replicates.",
  "tools": [
    {
      "name": "fastqc",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "QC on raw reads to assess read quality and adapter content",
      "language": "CLI"
    },
    {
      "name": "trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming using Nextera adapters specific to ATAC-seq",
      "language": "CLI"
    },
    {
      "name": "bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Short-read alignment to reference genome (splice-unaware, preferred for ATAC-seq)",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped, low MAPQ (<30), and mitochondrial reads from BAM",
      "language": "CLI"
    },
    {
      "name": "picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Remove PCR duplicates with MarkDuplicates",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads +4/-5 bp to correct for Tn5 transposase insertion bias and generate bigWig tracks",
      "language": "CLI"
    },
    {
      "name": "macs2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks with --nomodel --shift -100 --extsize 200",
      "language": "CLI"
    },
    {
      "name": "idr",
      "version": "2.0.3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/idr",
        "tag": "2.0.3--py27h2d50403_0",
        "full_uri": "quay.io/biocontainers/idr:2.0.3--py27h2d50403_0",
        "source": "biocontainers"
      },
      "purpose": "Irreproducibility Discovery Rate filtering to retain reproducible peaks across replicates",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq specific QC metrics including TSS enrichment and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "homer",
      "version": "4.9.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/homer",
        "tag": "4.9.1--pl5.22.0_4",
        "full_uri": "quay.io/biocontainers/homer:4.9.1--pl5.22.0_4",
        "source": "biocontainers"
      },
      "purpose": "Transcription factor motif enrichment analysis within called peaks",
      "language": "CLI"
    },
    {
      "name": "chipseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate peaks to nearest gene, promoter, and enhancer regions",
      "language": "R"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC reports into a single HTML summary report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "fastqc",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/NexteraPE-PE.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "index": "resources/genome/bowtie2_index",
        "threads": 8,
        "maxins": 2000
      },
      "shell_cmd": "bowtie2 -p {params.threads} -X {params.maxins} --no-mixed --no-discordant -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - | samtools sort -o {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 40000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "chrM": "chrM"
      },
      "shell_cmd": "samtools view -b -F 1804 -f 2 -q {params.mapq} -@ {params.threads} {input[0]} | samtools view -b --without-header $(samtools view -H {input[0]} | grep -v '{params.chrM}' | grep '^@SQ' | sed 's/@SQ\\tSN:\\([^\\t]*\\).*/\\1/' | tr '\\n' ' ') > {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/samtools_filter/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "deduped/{sample}.deduped.bam",
        "qc/picard/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g",
        "remove_duplicates": "true",
        "validation_stringency": "LENIENT"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES={params.remove_duplicates} VALIDATION_STRINGENCY={params.validation_stringency} 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.deduped.bam"
      ],
      "output": [
        "shifted/{sample}.shifted.bam"
      ],
      "params": {
        "shift_plus": 4,
        "shift_minus": -5,
        "threads": 4
      },
      "shell_cmd": "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/deeptools_shift/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "macs2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls"
      ],
      "params": {
        "outdir": "peaks",
        "genome_size": "hs",
        "qvalue": 0.05,
        "shift": -100,
        "extsize": 200,
        "format": "BAMPE"
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -f {params.format} -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --call-summits 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 10000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "idr_filter",
      "tool": "idr",
      "input": [
        "peaks/{rep1}_peaks.narrowPeak",
        "peaks/{rep2}_peaks.narrowPeak"
      ],
      "output": [
        "idr/{condition}_idr_peaks.narrowPeak",
        "idr/{condition}_idr_peaks.bed"
      ],
      "params": {
        "idr_threshold": 0.05,
        "input_file_type": "narrowPeak",
        "rank": "signal.value",
        "soft_idr_threshold": 0.1,
        "plot": "--plot"
      },
      "shell_cmd": "idr --samples {input[0]} {input[1]} --input-file-type {params.input_file_type} --rank {params.rank} --peak-merge-method sum --soft-idr-threshold {params.soft_idr_threshold} --idr-threshold {params.idr_threshold} {params.plot} --output-file {output[0]} --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\\t\"}} {{print $1,$2,$3,$4,$5,$6}}' {output[0]} > {output[1]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/idr/{condition}.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.shifted.bam",
        "idr/{condition}_idr_peaks.narrowPeak"
      ],
      "output": [
        "qc/ataqv/{sample}.ataqv.json",
        "qc/ataqv/{sample}.ataqv.txt"
      ],
      "params": {
        "genome_name": "human",
        "tss_file": "resources/tss.bed",
        "thread_count": 4
      },
      "shell_cmd": "ataqv --peak-file {input[1]} --name {wildcards.sample} --metrics-file {output[0]} --tss-file {params.tss_file} --thread-count {params.thread_count} {params.genome_name} {input[0]} > {output[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "bigwig/{sample}.bw"
      ],
      "params": {
        "threads": 8,
        "bin_size": 10,
        "normalize_using": "RPKM",
        "effective_genome_size": 2700000000
      },
      "shell_cmd": "bamCoverage --bam {input[0]} --outFileName {output[0]} --outFileFormat bigwig --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 10000
      },
      "log": [
        "logs/bamcoverage/{sample}.log"
      ]
    },
    {
      "name": "motif_analysis",
      "tool": "homer",
      "input": [
        "idr/{condition}_idr_peaks.bed"
      ],
      "output": [
        "motifs/{condition}/knownResults.html",
        "motifs/{condition}/homerResults.html"
      ],
      "params": {
        "genome": "hg38",
        "size": 200,
        "threads": 4,
        "outdir": "motifs/{condition}"
      },
      "shell_cmd": "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -p {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 10000
      },
      "log": [
        "logs/homer/{condition}.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "chipseeker",
      "input": [
        "idr/{condition}_idr_peaks.narrowPeak"
      ],
      "output": [
        "annotation/{condition}_peak_annotation.tsv",
        "annotation/{condition}_peak_annotation.pdf"
      ],
      "params": {
        "genome": "hg38",
        "tss_region_start": -3000,
        "tss_region_end": 3000
      },
      "shell_cmd": "Rscript scripts/chipseeker_annotate.R --peaks {input[0]} --genome {params.genome} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} --outtsv {output[0]} --outpdf {output[1]} 2> {log[0]}",
      "script": "scripts/chipseeker_annotate.R",
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/chipseeker/{condition}.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "multiqc",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "logs/bowtie2",
        "qc/picard",
        "qc/ataqv",
        "bigwig",
        "motifs",
        "annotation"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "title": "ATAC-seq QC Report"
      },
      "shell_cmd": "multiqc {input} --outdir {params.outdir} --title \"{params.title}\" --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "call_peaks",
      "idr_filter"
    ],
    [
      "idr_filter",
      "peak_qc"
    ],
    [
      "shift_reads",
      "peak_qc"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "idr_filter",
      "motif_analysis"
    ],
    [
      "idr_filter",
      "annotate_peaks"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "create_bigwig",
      "multiqc_report"
    ],
    [
      "motif_analysis",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2"
    ],
    "replicates": {
      "condition1": [
        "sample1_rep1",
        "sample1_rep2"
      ],
      "condition2": [
        "sample2_rep1",
        "sample2_rep2"
      ]
    },
    "genome": "hg38",
    "bowtie2_index": "resources/genome/bowtie2_index",
    "nextera_adapters": "resources/NexteraPE-PE.fa",
    "tss_file": "resources/tss.bed",
    "effective_genome_size": 2700000000,
    "macs2_genome_size": "hs",
    "macs2_qvalue": 0.05,
    "macs2_shift": -100,
    "macs2_extsize": 200,
    "idr_threshold": 0.05,
    "mapq_threshold": 30,
    "min_read_length": 36,
    "bigwig_bin_size": 10,
    "bigwig_normalization": "RPKM",
    "homer_genome": "hg38",
    "motif_size": 200,
    "tss_region": [
      -3000,
      3000
    ]
  },
  "wildcards": [
    "sample",
    "condition",
    "rep1",
    "rep2"
  ]
}