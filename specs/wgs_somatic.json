{
  "pipeline_type": "somatic-variant-calling",
  "description": "Somatic variant calling using GATK4 Mutect2 for paired tumor-normal samples following GATK best practices.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw FASTQ reads for both tumor and normal samples",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "bwa-mem2",
      "version": "2.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bwa-mem2",
        "tag": "2.0--he513fc3_0",
        "full_uri": "quay.io/biocontainers/bwa-mem2:2.0--he513fc3_0",
        "source": "biocontainers"
      },
      "purpose": "Align trimmed reads to reference genome for tumor and normal samples",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Coordinate-sort and index aligned BAM files",
      "language": "CLI"
    },
    {
      "name": "picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Mark PCR duplicates with MarkDuplicates (do not remove for GATK)",
      "language": "CLI"
    },
    {
      "name": "gatk4",
      "version": "4.0.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/gatk4",
        "tag": "4.0.0.0--py36_0",
        "full_uri": "quay.io/biocontainers/gatk4:4.0.0.0--py36_0",
        "source": "biocontainers"
      },
      "purpose": "GATK4 suite: BaseRecalibrator, ApplyBQSR, Mutect2, GetPileupSummaries, CalculateContamination, LearnReadOrientationModel, FilterMutectCalls",
      "language": "CLI"
    },
    {
      "name": "vep",
      "version": "99.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ensembl-vep",
        "tag": "99.0--pl526hecc5488_0",
        "full_uri": "quay.io/biocontainers/ensembl-vep:99.0--pl526hecc5488_0",
        "source": "biocontainers"
      },
      "purpose": "Functional annotation of somatic variants (Ensembl VEP)",
      "language": "CLI"
    },
    {
      "name": "bcftools",
      "version": "1.7",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bcftools",
        "tag": "1.7--0",
        "full_uri": "quay.io/biocontainers/bcftools:1.7--0",
        "source": "biocontainers"
      },
      "purpose": "Generate VCF statistics and summary metrics",
      "language": "CLI"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC reports into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "fastqc_raw",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 8
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 40000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "bwa_mem2_align",
      "tool": "bwa-mem2",
      "input": [
        "trimmed/{sample}_R1_paired.fastq.gz",
        "trimmed/{sample}_R2_paired.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "threads": 16,
        "read_group": "@RG\\tID:{sample}\\tSM:{sample}\\tPL:ILLUMINA\\tLB:{sample}"
      },
      "shell_cmd": "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.ref} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 16,
        "mem_mb": 32000,
        "time_min": 240,
        "disk_mb": 80000
      },
      "log": [
        "logs/bwa_mem2/{sample}.log"
      ]
    },
    {
      "name": "samtools_sort_index",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai"
      ],
      "params": {
        "threads": 8
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 60000
      },
      "log": [
        "logs/samtools/{sample}.log"
      ]
    },
    {
      "name": "mark_duplicates",
      "tool": "picard",
      "input": [
        "sorted/{sample}.sorted.bam"
      ],
      "output": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "dedup/{sample}.metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} CREATE_INDEX=true VALIDATION_STRINGENCY=SILENT 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 120,
        "disk_mb": 60000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "base_recalibrator",
      "tool": "gatk4",
      "input": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai"
      ],
      "output": [
        "bqsr/{sample}.recal.table"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "known_sites_dbsnp": "resources/dbsnp.vcf.gz",
        "known_sites_mills": "resources/mills_indels.vcf.gz",
        "known_sites_1000g": "resources/1000g_indels.vcf.gz",
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.ref} --known-sites {params.known_sites_dbsnp} --known-sites {params.known_sites_mills} --known-sites {params.known_sites_1000g} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 180,
        "disk_mb": 30000
      },
      "log": [
        "logs/bqsr/base_recalibrator_{sample}.log"
      ]
    },
    {
      "name": "apply_bqsr",
      "tool": "gatk4",
      "input": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "bqsr/{sample}.recal.table"
      ],
      "output": [
        "bqsr/{sample}.bqsr.bam",
        "bqsr/{sample}.bqsr.bam.bai"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' ApplyBQSR -I {input[0]} -R {params.ref} --bqsr-recal-file {input[2]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 180,
        "disk_mb": 60000
      },
      "log": [
        "logs/bqsr/apply_bqsr_{sample}.log"
      ]
    },
    {
      "name": "mutect2",
      "tool": "gatk4",
      "input": [
        "bqsr/{tumor_sample}.bqsr.bam",
        "bqsr/{tumor_sample}.bqsr.bam.bai",
        "bqsr/{normal_sample}.bqsr.bam",
        "bqsr/{normal_sample}.bqsr.bam.bai"
      ],
      "output": [
        "mutect2/{tumor_sample}_vs_{normal_sample}.vcf.gz",
        "mutect2/{tumor_sample}_vs_{normal_sample}.vcf.gz.tbi",
        "mutect2/{tumor_sample}_vs_{normal_sample}.f1r2.tar.gz",
        "mutect2/{tumor_sample}_vs_{normal_sample}.stats"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "germline_resource": "resources/af-only-gnomad.vcf.gz",
        "pon": "resources/panel_of_normals.vcf.gz",
        "java_opts": "-Xmx16g",
        "threads": 4
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' Mutect2 -R {params.ref} -I {input[0]} -tumor {wildcards.tumor_sample} -I {input[2]} -normal {wildcards.normal_sample} --germline-resource {params.germline_resource} --panel-of-normals {params.pon} --f1r2-tar-gz {output[2]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 480,
        "disk_mb": 60000
      },
      "log": [
        "logs/mutect2/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "get_pileup_summaries",
      "tool": "gatk4",
      "input": [
        "bqsr/{sample}.bqsr.bam",
        "bqsr/{sample}.bqsr.bam.bai"
      ],
      "output": [
        "contamination/{sample}.pileup.table"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "germline_resource": "resources/small_exac_common.vcf.gz",
        "java_opts": "-Xmx8g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' GetPileupSummaries -I {input[0]} -R {params.ref} -V {params.germline_resource} -L {params.germline_resource} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 12000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/get_pileup_summaries/{sample}.log"
      ]
    },
    {
      "name": "calculate_contamination",
      "tool": "gatk4",
      "input": [
        "contamination/{tumor_sample}.pileup.table",
        "contamination/{normal_sample}.pileup.table"
      ],
      "output": [
        "contamination/{tumor_sample}_vs_{normal_sample}.contamination.table",
        "contamination/{tumor_sample}_vs_{normal_sample}.segmentation.table"
      ],
      "params": {
        "java_opts": "-Xmx8g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' CalculateContamination -I {input[0]} -matched {input[1]} --tumor-segmentation {output[1]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 10000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/calculate_contamination/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "learn_read_orientation_model",
      "tool": "gatk4",
      "input": [
        "mutect2/{tumor_sample}_vs_{normal_sample}.f1r2.tar.gz"
      ],
      "output": [
        "mutect2/{tumor_sample}_vs_{normal_sample}.read_orientation_model.tar.gz"
      ],
      "params": {
        "java_opts": "-Xmx8g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' LearnReadOrientationModel -I {input[0]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 10000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/learn_read_orientation/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "filter_mutect_calls",
      "tool": "gatk4",
      "input": [
        "mutect2/{tumor_sample}_vs_{normal_sample}.vcf.gz",
        "mutect2/{tumor_sample}_vs_{normal_sample}.vcf.gz.tbi",
        "mutect2/{tumor_sample}_vs_{normal_sample}.stats",
        "contamination/{tumor_sample}_vs_{normal_sample}.contamination.table",
        "contamination/{tumor_sample}_vs_{normal_sample}.segmentation.table",
        "mutect2/{tumor_sample}_vs_{normal_sample}.read_orientation_model.tar.gz"
      ],
      "output": [
        "filtered/{tumor_sample}_vs_{normal_sample}.filtered.vcf.gz",
        "filtered/{tumor_sample}_vs_{normal_sample}.filtered.vcf.gz.tbi"
      ],
      "params": {
        "ref": "resources/reference/genome.fa",
        "java_opts": "-Xmx8g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' FilterMutectCalls -R {params.ref} -V {input[0]} --stats {input[2]} --contamination-table {input[3]} --tumor-segmentation {input[4]} --ob-priors {input[5]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 12000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/filter_mutect_calls/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "vep_annotate",
      "tool": "vep",
      "input": [
        "filtered/{tumor_sample}_vs_{normal_sample}.filtered.vcf.gz"
      ],
      "output": [
        "annotated/{tumor_sample}_vs_{normal_sample}.annotated.vcf.gz",
        "annotated/{tumor_sample}_vs_{normal_sample}.annotated.vcf.gz.tbi",
        "annotated/{tumor_sample}_vs_{normal_sample}.vep_summary.html"
      ],
      "params": {
        "vep_cache": "resources/vep_cache",
        "species": "homo_sapiens",
        "assembly": "GRCh38",
        "threads": 4
      },
      "shell_cmd": "vep --input_file {input[0]} --output_file {output[0]} --stats_file {output[2]} --vcf --compress_output bgzip --cache --dir_cache {params.vep_cache} --species {params.species} --assembly {params.assembly} --fork {params.threads} --everything --force_overwrite 2> {log[0]} && tabix -p vcf {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 180,
        "disk_mb": 40000
      },
      "log": [
        "logs/vep/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "bcftools_stats",
      "tool": "bcftools",
      "input": [
        "annotated/{tumor_sample}_vs_{normal_sample}.annotated.vcf.gz"
      ],
      "output": [
        "qc/bcftools/{tumor_sample}_vs_{normal_sample}.stats.txt"
      ],
      "params": {},
      "shell_cmd": "bcftools stats {input[0]} > {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/bcftools/{tumor_sample}_vs_{normal_sample}.log"
      ]
    },
    {
      "name": "multiqc",
      "tool": "multiqc",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "dedup",
        "qc/bcftools"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "config": "resources/multiqc_config.yaml"
      },
      "shell_cmd": "multiqc qc/fastqc logs/trimmomatic dedup qc/bcftools --outdir {params.outdir} --config {params.config} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "fastqc_raw",
      "trim_reads"
    ],
    [
      "trim_reads",
      "bwa_mem2_align"
    ],
    [
      "bwa_mem2_align",
      "samtools_sort_index"
    ],
    [
      "samtools_sort_index",
      "mark_duplicates"
    ],
    [
      "mark_duplicates",
      "base_recalibrator"
    ],
    [
      "base_recalibrator",
      "apply_bqsr"
    ],
    [
      "apply_bqsr",
      "mutect2"
    ],
    [
      "apply_bqsr",
      "get_pileup_summaries"
    ],
    [
      "get_pileup_summaries",
      "calculate_contamination"
    ],
    [
      "mutect2",
      "learn_read_orientation_model"
    ],
    [
      "mutect2",
      "filter_mutect_calls"
    ],
    [
      "calculate_contamination",
      "filter_mutect_calls"
    ],
    [
      "learn_read_orientation_model",
      "filter_mutect_calls"
    ],
    [
      "filter_mutect_calls",
      "vep_annotate"
    ],
    [
      "vep_annotate",
      "bcftools_stats"
    ],
    [
      "bcftools_stats",
      "multiqc"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1_tumor",
      "sample1_normal",
      "sample2_tumor",
      "sample2_normal"
    ],
    "tumor_normal_pairs": {
      "sample1_tumor": "sample1_normal",
      "sample2_tumor": "sample2_normal"
    },
    "paired_end": true,
    "strandedness": 0,
    "reference": "resources/reference/genome.fa",
    "adapters": "resources/adapters.fa",
    "dbsnp": "resources/dbsnp.vcf.gz",
    "mills_indels": "resources/mills_indels.vcf.gz",
    "1000g_indels": "resources/1000g_indels.vcf.gz",
    "germline_resource": "resources/af-only-gnomad.vcf.gz",
    "small_exac_common": "resources/small_exac_common.vcf.gz",
    "panel_of_normals": "resources/panel_of_normals.vcf.gz",
    "vep_cache": "resources/vep_cache",
    "vep_species": "homo_sapiens",
    "vep_assembly": "GRCh38",
    "multiqc_config": "resources/multiqc_config.yaml"
  },
  "wildcards": [
    "sample",
    "tumor_sample",
    "normal_sample"
  ]
}