{
  "pipeline_type": "wgs-variant-calling",
  "description": "Whole genome sequencing germline variant calling following GATK4 Best Practices with HaplotypeCaller in GVCF mode and joint genotyping.",
  "tools": [
    {
      "name": "fastqc",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw FASTQ reads",
      "language": "CLI"
    },
    {
      "name": "trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "bwa-mem2",
      "version": "2.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bwa-mem2",
        "tag": "2.0--he513fc3_0",
        "full_uri": "quay.io/biocontainers/bwa-mem2:2.0--he513fc3_0",
        "source": "biocontainers"
      },
      "purpose": "Align trimmed reads to reference genome using BWA-MEM2",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Coordinate sort and index aligned BAM files",
      "language": "CLI"
    },
    {
      "name": "picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Mark PCR duplicates with MarkDuplicates (retain for GATK BQSR)",
      "language": "CLI"
    },
    {
      "name": "gatk4",
      "version": "4.0.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/gatk4",
        "tag": "4.0.0.0--py36_0",
        "full_uri": "quay.io/biocontainers/gatk4:4.0.0.0--py36_0",
        "source": "biocontainers"
      },
      "purpose": "GATK4 suite: BQSR, HaplotypeCaller, CombineGVCFs, GenotypeGVCFs, VariantFiltration",
      "language": "CLI"
    },
    {
      "name": "bcftools",
      "version": "1.7",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bcftools",
        "tag": "1.7--0",
        "full_uri": "quay.io/biocontainers/bcftools:1.7--0",
        "source": "biocontainers"
      },
      "purpose": "Generate summary statistics on final annotated VCF",
      "language": "CLI"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC logs into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "fastqc",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/adapters.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bwa",
      "tool": "bwa-mem2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "threads": 16,
        "read_group": "@RG\\tID:{sample}\\tSM:{sample}\\tPL:ILLUMINA\\tLB:{sample}"
      },
      "shell_cmd": "bwa-mem2 mem -t {params.threads} -R '{params.read_group}' {params.reference} {input[0]} {input[1]} | samtools view -bS - > {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 16,
        "mem_mb": 32000,
        "time_min": 240,
        "disk_mb": 60000
      },
      "log": [
        "logs/bwa_mem2/{sample}.log"
      ]
    },
    {
      "name": "sort_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "sorted/{sample}.sorted.bam",
        "sorted/{sample}.sorted.bam.bai"
      ],
      "params": {
        "threads": 8
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} 2> {log[0]} && samtools index {output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 60000
      },
      "log": [
        "logs/samtools_sort/{sample}.log"
      ]
    },
    {
      "name": "mark_duplicates",
      "tool": "picard",
      "input": [
        "sorted/{sample}.sorted.bam"
      ],
      "output": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai",
        "qc/picard/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[2]} CREATE_INDEX=true ASSUME_SORTED=true VALIDATION_STRINGENCY=SILENT 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 180,
        "disk_mb": 60000
      },
      "log": [
        "logs/picard_markdup/{sample}.log"
      ]
    },
    {
      "name": "base_recalibration",
      "tool": "gatk4",
      "input": [
        "dedup/{sample}.dedup.bam",
        "dedup/{sample}.dedup.bam.bai"
      ],
      "output": [
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai",
        "bqsr/{sample}.recal_data.table"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "known_sites_dbsnp": "resources/known_sites/dbsnp.vcf.gz",
        "known_sites_mills": "resources/known_sites/mills_gold.vcf.gz",
        "known_sites_1kg": "resources/known_sites/1000G_phase1.vcf.gz",
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' BaseRecalibrator -I {input[0]} -R {params.reference} --known-sites {params.known_sites_dbsnp} --known-sites {params.known_sites_mills} --known-sites {params.known_sites_1kg} -O {output[2]} 2> {log[0]} && gatk --java-options '{params.java_opts}' ApplyBQSR -R {params.reference} -I {input[0]} --bqsr-recal-file {output[2]} -O {output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 20000,
        "time_min": 300,
        "disk_mb": 60000
      },
      "log": [
        "logs/bqsr/{sample}.log"
      ]
    },
    {
      "name": "haplotype_caller",
      "tool": "gatk4",
      "input": [
        "bqsr/{sample}.recal.bam",
        "bqsr/{sample}.recal.bam.bai"
      ],
      "output": [
        "gvcf/{sample}.g.vcf.gz",
        "gvcf/{sample}.g.vcf.gz.tbi"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' HaplotypeCaller -R {params.reference} -I {input[0]} -O {output[0]} -ERC GVCF --tmp-dir tmp/ 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 20000,
        "time_min": 480,
        "disk_mb": 30000
      },
      "log": [
        "logs/haplotypecaller/{sample}.log"
      ]
    },
    {
      "name": "combine_gvcfs",
      "tool": "gatk4",
      "input": [
        "gvcf/all_samples.gvcf_list.txt"
      ],
      "output": [
        "joint/combined.g.vcf.gz",
        "joint/combined.g.vcf.gz.tbi"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "java_opts": "-Xmx32g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' CombineGVCFs -R {params.reference} $(awk '{{print \"--variant \" $1}}' {input[0]}) -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 480,
        "disk_mb": 60000
      },
      "log": [
        "logs/combine_gvcfs/combined.log"
      ]
    },
    {
      "name": "genotype_gvcfs",
      "tool": "gatk4",
      "input": [
        "joint/combined.g.vcf.gz",
        "joint/combined.g.vcf.gz.tbi"
      ],
      "output": [
        "joint/genotyped.vcf.gz",
        "joint/genotyped.vcf.gz.tbi"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "java_opts": "-Xmx32g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' GenotypeGVCFs -R {params.reference} -V {input[0]} -O {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 300,
        "disk_mb": 30000
      },
      "log": [
        "logs/genotype_gvcfs/genotyped.log"
      ]
    },
    {
      "name": "variant_filtration",
      "tool": "gatk4",
      "input": [
        "joint/genotyped.vcf.gz",
        "joint/genotyped.vcf.gz.tbi"
      ],
      "output": [
        "filtered/filtered.vcf.gz",
        "filtered/filtered.vcf.gz.tbi"
      ],
      "params": {
        "reference": "resources/reference/genome.fa",
        "snp_filter_expr": "QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0",
        "snp_filter_name": "SNP_HARD_FILTER",
        "indel_filter_expr": "QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0",
        "indel_filter_name": "INDEL_HARD_FILTER",
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include SNP -O filtered/snps_raw.vcf.gz 2> {log[0]} && gatk --java-options '{params.java_opts}' SelectVariants -R {params.reference} -V {input[0]} --select-type-to-include INDEL -O filtered/indels_raw.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/snps_raw.vcf.gz --filter-expression '{params.snp_filter_expr}' --filter-name '{params.snp_filter_name}' -O filtered/snps_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' VariantFiltration -R {params.reference} -V filtered/indels_raw.vcf.gz --filter-expression '{params.indel_filter_expr}' --filter-name '{params.indel_filter_name}' -O filtered/indels_filtered.vcf.gz 2>> {log[0]} && gatk --java-options '{params.java_opts}' MergeVcfs I=filtered/snps_filtered.vcf.gz I=filtered/indels_filtered.vcf.gz O={output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 20000,
        "time_min": 180,
        "disk_mb": 30000
      },
      "log": [
        "logs/variant_filtration/filtered.log"
      ]
    },
    {
      "name": "annotate_variants",
      "tool": "bcftools",
      "input": [
        "filtered/filtered.vcf.gz",
        "filtered/filtered.vcf.gz.tbi"
      ],
      "output": [
        "annotated/annotated.vcf.gz",
        "annotated/annotated.vcf.gz.tbi"
      ],
      "params": {
        "dbsnp": "resources/known_sites/dbsnp.vcf.gz",
        "threads": 4
      },
      "shell_cmd": "bcftools annotate --threads {params.threads} -a {params.dbsnp} -c ID -O z -o {output[0]} {input[0]} 2> {log[0]} && bcftools index --tbi {output[0]} 2>> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/annotate_variants/annotated.log"
      ]
    },
    {
      "name": "variant_qc",
      "tool": "bcftools",
      "input": [
        "annotated/annotated.vcf.gz",
        "annotated/annotated.vcf.gz.tbi"
      ],
      "output": [
        "qc/bcftools/variant_stats.txt"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "bcftools stats --threads {params.threads} {input[0]} > {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 5000
      },
      "log": [
        "logs/bcftools_stats/variant_stats.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "multiqc",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "qc/picard",
        "qc/bcftools/variant_stats.txt"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "search_dirs": "qc/ logs/"
      },
      "shell_cmd": "multiqc {params.search_dirs} --outdir {params.outdir} --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bwa"
    ],
    [
      "align_bwa",
      "sort_bam"
    ],
    [
      "sort_bam",
      "mark_duplicates"
    ],
    [
      "mark_duplicates",
      "base_recalibration"
    ],
    [
      "base_recalibration",
      "haplotype_caller"
    ],
    [
      "haplotype_caller",
      "combine_gvcfs"
    ],
    [
      "combine_gvcfs",
      "genotype_gvcfs"
    ],
    [
      "genotype_gvcfs",
      "variant_filtration"
    ],
    [
      "variant_filtration",
      "annotate_variants"
    ],
    [
      "annotate_variants",
      "variant_qc"
    ],
    [
      "variant_qc",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3"
    ],
    "paired_end": true,
    "strandedness": 0,
    "reference": "resources/reference/genome.fa",
    "adapters": "resources/adapters.fa",
    "known_sites_dbsnp": "resources/known_sites/dbsnp.vcf.gz",
    "known_sites_mills": "resources/known_sites/mills_gold.vcf.gz",
    "known_sites_1kg": "resources/known_sites/1000G_phase1.vcf.gz",
    "genome_build": "hg38",
    "bwa_threads": 16,
    "haplotypecaller_threads": 8,
    "java_opts_default": "-Xmx16g",
    "java_opts_high_mem": "-Xmx32g",
    "snp_filter_expr": "QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0",
    "indel_filter_expr": "QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0",
    "min_read_length": 36,
    "leading_quality": 3,
    "trailing_quality": 3,
    "sliding_window": "4:15"
  },
  "wildcards": [
    "sample"
  ]
}