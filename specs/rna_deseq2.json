{
  "pipeline_type": "rna-seq-de",
  "description": "Bulk RNA-seq differential expression analysis pipeline using STAR alignment and DESeq2 for identifying differentially expressed genes between conditions.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw and trimmed reads to assess read quality metrics",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter removal and quality trimming of raw reads",
      "language": "CLI"
    },
    {
      "name": "STAR",
      "version": "2.5.4a",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/star",
        "tag": "2.5.4a--0",
        "full_uri": "quay.io/biocontainers/star:2.5.4a--0",
        "source": "biocontainers"
      },
      "purpose": "Splice-aware alignment of trimmed reads to reference genome",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Sort and index aligned BAM files for downstream processing",
      "language": "CLI"
    },
    {
      "name": "featureCounts",
      "version": "1.5.0p3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/subread",
        "tag": "1.5.0p3--0",
        "full_uri": "quay.io/biocontainers/subread:1.5.0p3--0",
        "source": "biocontainers"
      },
      "purpose": "Gene-level read quantification to generate count matrix",
      "language": "CLI"
    },
    {
      "name": "DESeq2",
      "version": "1.20.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-deseq2",
        "tag": "1.20.0--r351hfc679d8_0",
        "full_uri": "quay.io/biocontainers/bioconductor-deseq2:1.20.0--r351hfc679d8_0",
        "source": "biocontainers"
      },
      "purpose": "Differential expression analysis generating results table, MA plot, and PCA",
      "language": "R"
    },
    {
      "name": "clusterProfiler",
      "version": "3.6.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-clusterprofiler",
        "tag": "3.6.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-clusterprofiler:3.6.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "GO and KEGG pathway enrichment analysis on DEGs",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC logs into a single HTML summary report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/raw/{sample}_R1_fastqc.html",
        "qc/raw/{sample}_R1_fastqc.zip",
        "qc/raw/{sample}_R2_fastqc.html",
        "qc/raw/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/raw",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/raw/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "config[adapters]",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "post_trim_fastqc",
      "tool": "FastQC",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/trimmed/{sample}_R1_fastqc.html",
        "qc/trimmed/{sample}_R1_fastqc.zip",
        "qc/trimmed/{sample}_R2_fastqc.html",
        "qc/trimmed/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/trimmed",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/trimmed/{sample}.log"
      ]
    },
    {
      "name": "align_star",
      "tool": "STAR",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}/Aligned.out.bam",
        "aligned/{sample}/Log.final.out"
      ],
      "params": {
        "genome_dir": "config[star_genome_dir]",
        "threads": 8,
        "outdir": "aligned/{sample}/"
      },
      "shell_cmd": "STAR --runThreadN {params.threads} --genomeDir {params.genome_dir} --readFilesIn {input[0]} {input[1]} --readFilesCommand zcat --outSAMtype BAM Unsorted --outSAMattributes NH HI AS NM --outFileNamePrefix {params.outdir} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 40000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/star/{sample}.log"
      ]
    },
    {
      "name": "sort_index_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}/Aligned.out.bam"
      ],
      "output": [
        "aligned/{sample}/{sample}.sorted.bam",
        "aligned/{sample}/{sample}.sorted.bam.bai"
      ],
      "params": {
        "threads": 4
      },
      "shell_cmd": "samtools sort -@ {params.threads} -o {output[0]} {input[0]} > {log[0]} 2>&1 && samtools index {output[0]} >> {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/samtools/{sample}.log"
      ]
    },
    {
      "name": "featurecounts",
      "tool": "featureCounts",
      "input": [
        "aligned/sample1/sample1.sorted.bam",
        "aligned/sample2/sample2.sorted.bam",
        "aligned/sample3/sample3.sorted.bam",
        "aligned/sample4/sample4.sorted.bam"
      ],
      "output": [
        "counts/all_samples_counts.txt",
        "counts/all_samples_counts.txt.summary"
      ],
      "params": {
        "gtf": "config[gtf_file]",
        "threads": 8,
        "strandedness": "config[strandedness]",
        "paired_end_flag": "config[paired_end]"
      },
      "shell_cmd": "featureCounts -T {params.threads} -s {params.strandedness} $(if [ \"{params.paired_end_flag}\" = \"True\" ]; then echo \"-p\"; fi) -a {params.gtf} -o {output[0]} {input} > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/featurecounts/featurecounts.log"
      ]
    },
    {
      "name": "differential_expr",
      "tool": "DESeq2",
      "input": [
        "counts/all_samples_counts.txt"
      ],
      "output": [
        "results/deseq2/de_results.csv",
        "results/deseq2/ma_plot.pdf",
        "results/deseq2/pca_plot.pdf",
        "results/deseq2/normalized_counts.csv"
      ],
      "params": {
        "sample_sheet": "config[sample_sheet]",
        "condition_col": "config[condition_col]",
        "reference_level": "config[reference_level]",
        "lfc_threshold": "config[lfc_threshold]",
        "padj_threshold": "config[padj_threshold]"
      },
      "shell_cmd": "Rscript scripts/run_deseq2.R --counts {input[0]} --sample_sheet {params.sample_sheet} --condition {params.condition_col} --reference {params.reference_level} --lfc_threshold {params.lfc_threshold} --padj_threshold {params.padj_threshold} --out_results {output[0]} --out_ma {output[1]} --out_pca {output[2]} --out_norm_counts {output[3]} > {log[0]} 2>&1",
      "script": "scripts/run_deseq2.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/deseq2/deseq2.log"
      ]
    },
    {
      "name": "go_enrichment",
      "tool": "clusterProfiler",
      "input": [
        "results/deseq2/de_results.csv"
      ],
      "output": [
        "results/enrichment/go_enrichment.csv",
        "results/enrichment/kegg_enrichment.csv",
        "results/enrichment/go_dotplot.pdf",
        "results/enrichment/kegg_dotplot.pdf"
      ],
      "params": {
        "organism_db": "config[organism_db]",
        "padj_threshold": "config[padj_threshold]",
        "lfc_threshold": "config[lfc_threshold]",
        "kegg_organism": "config[kegg_organism]"
      },
      "shell_cmd": "Rscript scripts/run_clusterprofiler.R --de_results {input[0]} --organism_db {params.organism_db} --kegg_organism {params.kegg_organism} --padj_threshold {params.padj_threshold} --lfc_threshold {params.lfc_threshold} --out_go {output[0]} --out_kegg {output[1]} --out_go_plot {output[2]} --out_kegg_plot {output[3]} > {log[0]} 2>&1",
      "script": "scripts/run_clusterprofiler.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/clusterprofiler/enrichment.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/raw",
        "qc/trimmed",
        "logs/star",
        "counts/all_samples_counts.txt.summary",
        "results/deseq2/de_results.csv"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "search_dirs": "qc/raw qc/trimmed logs/star counts results/deseq2"
      },
      "shell_cmd": "multiqc {params.search_dirs} --outdir {params.outdir} --force > {log[0]} 2>&1",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 4000,
        "time_min": 30,
        "disk_mb": 5000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "post_trim_fastqc"
    ],
    [
      "post_trim_fastqc",
      "align_star"
    ],
    [
      "align_star",
      "sort_index_bam"
    ],
    [
      "sort_index_bam",
      "featurecounts"
    ],
    [
      "featurecounts",
      "differential_expr"
    ],
    [
      "differential_expr",
      "go_enrichment"
    ],
    [
      "raw_fastqc",
      "multiqc_report"
    ],
    [
      "post_trim_fastqc",
      "multiqc_report"
    ],
    [
      "align_star",
      "multiqc_report"
    ],
    [
      "featurecounts",
      "multiqc_report"
    ],
    [
      "differential_expr",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3",
      "sample4"
    ],
    "strandedness": 0,
    "paired_end": true,
    "adapters": "resources/adapters.fa",
    "star_genome_dir": "resources/star_genome",
    "gtf_file": "resources/annotation.gtf",
    "sample_sheet": "config/sample_sheet.csv",
    "condition_col": "condition",
    "reference_level": "control",
    "lfc_threshold": 1.0,
    "padj_threshold": 0.05,
    "organism_db": "org.Hs.eg.db",
    "kegg_organism": "hsa"
  },
  "wildcards": [
    "sample"
  ]
}