{
  "pipeline_type": "atac-seq",
  "description": "ATAC-seq chromatin accessibility pipeline with MACS2 peak calling and IDR filtering for reproducible peak identification across biological replicates.",
  "tools": [
    {
      "name": "FastQC",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "QC on raw reads to assess read quality and adapter contamination",
      "language": "CLI"
    },
    {
      "name": "Trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming using Nextera adapter sequences specific to ATAC-seq",
      "language": "CLI"
    },
    {
      "name": "Bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Alignment of trimmed reads to reference genome",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "1.17",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "1.17--h00cdaf9_0",
        "full_uri": "quay.io/biocontainers/samtools:1.17--h00cdaf9_0",
        "source": "biocontainers"
      },
      "purpose": "Filter BAM: remove unmapped, low MAPQ (<30), and mitochondrial reads",
      "language": "CLI"
    },
    {
      "name": "Picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "MarkDuplicates: remove PCR duplicates from aligned BAM",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "alignmentSieve to shift reads for Tn5 bias correction; bamCoverage to generate bigWig tracks",
      "language": "CLI"
    },
    {
      "name": "MACS2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks per replicate using --nomodel --shift -100 --extsize 200",
      "language": "CLI"
    },
    {
      "name": "IDR",
      "version": "2.0.3",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/idr",
        "tag": "2.0.3--py27_0",
        "full_uri": "quay.io/biocontainers/idr:2.0.3--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Irreproducibility Discovery Rate filtering to retain reproducible peaks across biological replicates",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq specific QC metrics including TSS enrichment score and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "ChIPseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate IDR peaks to nearest gene, promoter, and enhancer regions",
      "language": "R"
    },
    {
      "name": "MultiQC",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC logs and metrics into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "FastQC",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/{sample}_R1_fastqc.html",
        "qc/fastqc/{sample}_R1_fastqc.zip",
        "qc/fastqc/{sample}_R2_fastqc.html",
        "qc/fastqc/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc",
        "threads": 4
      },
      "shell_cmd": "fastqc --threads {params.threads} --outdir {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "Trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "config[nextera_adapters]",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 20,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "Bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "index": "config[bowtie2_index]",
        "threads": 8,
        "max_insert": 2000
      },
      "shell_cmd": "bowtie2 -p {params.threads} -X {params.max_insert} --very-sensitive -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "chrM": "config[mito_chrom]"
      },
      "shell_cmd": "samtools view -@ {params.threads} -F 1804 -f 2 -q {params.mapq} -b {input[0]} | samtools view -@ {params.threads} -b --exclude-flags 0 - | grep -v '{params.chrM}' | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 20000
      },
      "log": [
        "logs/filter_bam/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "Picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "deduped/{sample}.deduped.bam",
        "deduped/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g"
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES=true ASSUME_SORTED=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.deduped.bam"
      ],
      "output": [
        "shifted/{sample}.shifted.bam"
      ],
      "params": {
        "threads": 4,
        "shift_plus": 4,
        "shift_minus": -5
      },
      "shell_cmd": "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools sort -@ {params.threads} -o {output[0]}.sorted.bam {output[0]} && mv {output[0]}.sorted.bam {output[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/shift_reads/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "bigwigs/{sample}.bw"
      ],
      "params": {
        "threads": 4,
        "bin_size": 10,
        "normalize": "RPKM"
      },
      "shell_cmd": "bamCoverage --numberOfProcessors {params.threads} --binSize {params.bin_size} --normalizeUsing {params.normalize} --bam {input[0]} -o {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/bigwig/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "MACS2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed"
      ],
      "params": {
        "outdir": "peaks",
        "genome_size": "config[genome_size]",
        "qvalue": 0.05,
        "shift": -100,
        "extsize": 200
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {wildcards.sample} --outdir {params.outdir} --nomodel --shift {params.shift} --extsize {params.extsize} -q {params.qvalue} --keep-dup all 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "idr_filtering",
      "tool": "IDR",
      "input": [
        "peaks/idr_input_rep1.narrowPeak",
        "peaks/idr_input_rep2.narrowPeak"
      ],
      "output": [
        "idr/idr_peaks.narrowPeak",
        "idr/idr_output.txt"
      ],
      "params": {
        "idr_threshold": 0.05,
        "rank": "signal.value",
        "peak_merge_method": "sum"
      },
      "shell_cmd": "idr --samples {input[0]} {input[1]} --input-file-type narrowPeak --rank {params.rank} --idr-threshold {params.idr_threshold} --peak-merge-method {params.peak_merge_method} --output-file {output[1]} --plot --log-output-file {log[0]} && awk 'BEGIN{{OFS=\"\\t\"}} $12>=({params.idr_threshold}*-1)*log(10)/log(10) {{print}}' {output[1]} > {output[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/idr/idr.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "idr/idr_peaks.narrowPeak",
        "deduped/all_samples_merged.bam"
      ],
      "output": [
        "qc/ataqv/ataqv_metrics.json",
        "qc/ataqv/ataqv_report.html"
      ],
      "params": {
        "tss_file": "config[tss_bed]",
        "organism": "config[organism]",
        "threads": 4
      },
      "shell_cmd": "ataqv --peak-file {input[0]} --tss-file {params.tss_file} --metrics-file {output[0]} {params.organism} {input[1]} 2> {log[0]} && mkarv --force {output[1]} {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/ataqv/ataqv.log"
      ]
    },
    {
      "name": "motif_analysis",
      "tool": "ChIPseeker",
      "input": [
        "idr/idr_peaks.narrowPeak"
      ],
      "output": [
        "motifs/motif_enrichment.txt",
        "motifs/known_motifs_results.txt"
      ],
      "params": {
        "genome": "config[genome_build]",
        "size": 200,
        "outdir": "motifs"
      },
      "shell_cmd": "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -mask 2> {log[0]} && cp {params.outdir}/knownResults.txt {output[1]} && cp {params.outdir}/homerResults.html {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 20000
      },
      "log": [
        "logs/motif/motif_analysis.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "ChIPseeker",
      "input": [
        "idr/idr_peaks.narrowPeak"
      ],
      "output": [
        "annotation/peak_annotation.tsv",
        "annotation/peak_annotation_plots.pdf"
      ],
      "params": {
        "genome_build": "config[genome_build]",
        "txdb": "config[txdb]",
        "organism_db": "config[organism_db]",
        "tss_region_start": -3000,
        "tss_region_end": 3000
      },
      "shell_cmd": "Rscript scripts/annotate_peaks.R --peaks {input[0]} --txdb {params.txdb} --organism_db {params.organism_db} --tss_start {params.tss_region_start} --tss_end {params.tss_region_end} --out_table {output[0]} --out_plots {output[1]} 2> {log[0]}",
      "script": "scripts/annotate_peaks.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/annotate_peaks.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "MultiQC",
      "input": [
        "qc/fastqc",
        "logs/trimmomatic",
        "logs/bowtie2",
        "deduped",
        "qc/ataqv/ataqv_metrics.json",
        "annotation/peak_annotation.tsv",
        "motifs/known_motifs_results.txt"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "config": "config[multiqc_config]"
      },
      "shell_cmd": "multiqc --force --config {params.config} --outdir {params.outdir} qc/fastqc logs/trimmomatic logs/bowtie2 deduped qc/ataqv 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "call_peaks",
      "idr_filtering"
    ],
    [
      "idr_filtering",
      "peak_qc"
    ],
    [
      "idr_filtering",
      "motif_analysis"
    ],
    [
      "idr_filtering",
      "annotate_peaks"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "create_bigwig",
      "multiqc_report"
    ],
    [
      "motif_analysis",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "rep1",
      "rep2"
    ],
    "paired_end": true,
    "strandedness": 0,
    "bowtie2_index": "resources/genome/hg38",
    "genome_size": "hs",
    "genome_build": "hg38",
    "nextera_adapters": "resources/NexteraPE-PE.fa",
    "mito_chrom": "chrM",
    "tss_bed": "resources/tss_hg38.bed",
    "organism": "human",
    "txdb": "TxDb.Hsapiens.UCSC.hg38.knownGene",
    "organism_db": "org.Hs.eg.db",
    "multiqc_config": "config/multiqc_config.yaml",
    "idr_threshold": 0.05,
    "macs2_qvalue": 0.05,
    "mapq_threshold": 30
  },
  "wildcards": [
    "sample"
  ]
}