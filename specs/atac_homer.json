{
  "pipeline_type": "atac-seq",
  "description": "ATAC-seq chromatin accessibility pipeline with Tn5 insertion site shift correction and transcription factor motif enrichment using HOMER.",
  "tools": [
    {
      "name": "fastqc",
      "version": "0.11.5",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/fastqc",
        "tag": "0.11.5--1",
        "full_uri": "quay.io/biocontainers/fastqc:0.11.5--1",
        "source": "biocontainers"
      },
      "purpose": "Quality control on raw FASTQ reads",
      "language": "CLI"
    },
    {
      "name": "trimmomatic",
      "version": "0.33",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/trimmomatic",
        "tag": "0.33--1",
        "full_uri": "quay.io/biocontainers/trimmomatic:0.33--1",
        "source": "biocontainers"
      },
      "purpose": "Adapter trimming using Nextera adapters specific to ATAC-seq",
      "language": "CLI"
    },
    {
      "name": "bowtie2",
      "version": "2.3.4.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bowtie2",
        "tag": "2.3.4.1--py35h2d50403_1",
        "full_uri": "quay.io/biocontainers/bowtie2:2.3.4.1--py35h2d50403_1",
        "source": "biocontainers"
      },
      "purpose": "Short-read alignment to reference genome (splice-unaware, preferred for ATAC-seq)",
      "language": "CLI"
    },
    {
      "name": "samtools",
      "version": "0.1.19",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/samtools",
        "tag": "0.1.19--2",
        "full_uri": "quay.io/biocontainers/samtools:0.1.19--2",
        "source": "biocontainers"
      },
      "purpose": "Filter unmapped, low MAPQ, and mitochondrial reads; sort and index BAM files",
      "language": "CLI"
    },
    {
      "name": "picard",
      "version": "2.9.2",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/picard",
        "tag": "2.9.2--py35_1",
        "full_uri": "quay.io/biocontainers/picard:2.9.2--py35_1",
        "source": "biocontainers"
      },
      "purpose": "Remove PCR duplicates via MarkDuplicates",
      "language": "CLI"
    },
    {
      "name": "deeptools",
      "version": "3.0.1",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/deeptools",
        "tag": "3.0.1--py27_0",
        "full_uri": "quay.io/biocontainers/deeptools:3.0.1--py27_0",
        "source": "biocontainers"
      },
      "purpose": "Shift reads for Tn5 insertion bias correction and generate normalized bigWig tracks",
      "language": "CLI"
    },
    {
      "name": "macs2",
      "version": "2.1.1.20160309",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/macs2",
        "tag": "2.1.1.20160309--py27h7eb728f_3",
        "full_uri": "quay.io/biocontainers/macs2:2.1.1.20160309--py27h7eb728f_3",
        "source": "biocontainers"
      },
      "purpose": "Call open chromatin peaks using --nomodel --shift -100 --extsize 200",
      "language": "CLI"
    },
    {
      "name": "ataqv",
      "version": "1.0.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/ataqv",
        "tag": "1.0.0--py27heba63b0_0",
        "full_uri": "quay.io/biocontainers/ataqv:1.0.0--py27heba63b0_0",
        "source": "biocontainers"
      },
      "purpose": "ATAC-seq specific QC including TSS enrichment score and fragment size distribution",
      "language": "CLI"
    },
    {
      "name": "homer",
      "version": "4.10",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/homer",
        "tag": "4.10--pl526h9a982cc_0",
        "full_uri": "quay.io/biocontainers/homer:4.10--pl526h9a982cc_0",
        "source": "biocontainers"
      },
      "purpose": "Transcription factor motif enrichment analysis within called peaks",
      "language": "CLI"
    },
    {
      "name": "chipseeker",
      "version": "1.10.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/bioconductor-chipseeker",
        "tag": "1.10.0--r3.4.1_0",
        "full_uri": "quay.io/biocontainers/bioconductor-chipseeker:1.10.0--r3.4.1_0",
        "source": "biocontainers"
      },
      "purpose": "Annotate peaks to nearest genomic features (promoters, enhancers, gene bodies)",
      "language": "R"
    },
    {
      "name": "multiqc",
      "version": "1.0",
      "container": {
        "registry": "quay.io",
        "image": "biocontainers/multiqc",
        "tag": "1.0--py36_1",
        "full_uri": "quay.io/biocontainers/multiqc:1.0--py36_1",
        "source": "biocontainers"
      },
      "purpose": "Aggregate all QC outputs into a single HTML report",
      "language": "CLI"
    }
  ],
  "rules": [
    {
      "name": "raw_fastqc",
      "tool": "fastqc",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "qc/fastqc/raw/{sample}_R1_fastqc.html",
        "qc/fastqc/raw/{sample}_R2_fastqc.html",
        "qc/fastqc/raw/{sample}_R1_fastqc.zip",
        "qc/fastqc/raw/{sample}_R2_fastqc.zip"
      ],
      "params": {
        "outdir": "qc/fastqc/raw",
        "threads": 4
      },
      "shell_cmd": "fastqc -t {params.threads} -o {params.outdir} {input[0]} {input[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 4000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/fastqc/raw/{sample}.log"
      ]
    },
    {
      "name": "trim_reads",
      "tool": "trimmomatic",
      "input": [
        "data/{sample}_R1.fastq.gz",
        "data/{sample}_R2.fastq.gz"
      ],
      "output": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R1_unpaired.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz",
        "trimmed/{sample}_R2_unpaired.fastq.gz"
      ],
      "params": {
        "adapters": "resources/NexteraPE-PE.fa",
        "leading": 3,
        "trailing": 3,
        "slidingwindow": "4:15",
        "minlen": 36,
        "threads": 4
      },
      "shell_cmd": "trimmomatic PE -threads {params.threads} {input[0]} {input[1]} {output[0]} {output[1]} {output[2]} {output[3]} ILLUMINACLIP:{params.adapters}:2:30:10 LEADING:{params.leading} TRAILING:{params.trailing} SLIDINGWINDOW:{params.slidingwindow} MINLEN:{params.minlen} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 8000,
        "time_min": 90,
        "disk_mb": 30000
      },
      "log": [
        "logs/trimmomatic/{sample}.log"
      ]
    },
    {
      "name": "align_bowtie2",
      "tool": "bowtie2",
      "input": [
        "trimmed/{sample}_R1.fastq.gz",
        "trimmed/{sample}_R2.fastq.gz"
      ],
      "output": [
        "aligned/{sample}.bam"
      ],
      "params": {
        "index": "resources/bowtie2_index/genome",
        "threads": 8,
        "max_fragment_size": 2000
      },
      "shell_cmd": "bowtie2 -p {params.threads} -X {params.max_fragment_size} --no-mixed --no-discordant -x {params.index} -1 {input[0]} -2 {input[1]} 2> {log[0]} | samtools view -bS - > {output[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 32000,
        "time_min": 180,
        "disk_mb": 50000
      },
      "log": [
        "logs/bowtie2/{sample}.log"
      ]
    },
    {
      "name": "filter_bam",
      "tool": "samtools",
      "input": [
        "aligned/{sample}.bam"
      ],
      "output": [
        "filtered/{sample}.filtered.bam",
        "filtered/{sample}.filtered.bam.bai"
      ],
      "params": {
        "mapq": 30,
        "threads": 4,
        "chrM": "chrM"
      },
      "shell_cmd": "samtools view -b -F 1804 -f 2 -q {params.mapq} {input[0]} | grep -v {params.chrM} | samtools sort -@ {params.threads} -o {output[0]} - && samtools index {output[0]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/samtools/filter/{sample}.log"
      ]
    },
    {
      "name": "remove_duplicates",
      "tool": "picard",
      "input": [
        "filtered/{sample}.filtered.bam"
      ],
      "output": [
        "deduped/{sample}.deduped.bam",
        "qc/picard/{sample}.dup_metrics.txt"
      ],
      "params": {
        "java_opts": "-Xmx16g",
        "threads": 4
      },
      "shell_cmd": "picard {params.java_opts} MarkDuplicates INPUT={input[0]} OUTPUT={output[0]} METRICS_FILE={output[1]} REMOVE_DUPLICATES=true VALIDATION_STRINGENCY=LENIENT 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 20000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/picard/{sample}.log"
      ]
    },
    {
      "name": "shift_reads",
      "tool": "deeptools",
      "input": [
        "deduped/{sample}.deduped.bam"
      ],
      "output": [
        "shifted/{sample}.shifted.bam",
        "shifted/{sample}.shifted.bam.bai"
      ],
      "params": {
        "threads": 4,
        "shift_plus": 4,
        "shift_minus": -5
      },
      "shell_cmd": "alignmentSieve --numberOfProcessors {params.threads} --ATACshift --bam {input[0]} -o {output[0]} 2> {log[0]} && samtools index {output[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 120,
        "disk_mb": 30000
      },
      "log": [
        "logs/deeptools/alignmentSieve/{sample}.log"
      ]
    },
    {
      "name": "call_peaks",
      "tool": "macs2",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "peaks/{sample}_peaks.narrowPeak",
        "peaks/{sample}_summits.bed",
        "peaks/{sample}_peaks.xls"
      ],
      "params": {
        "genome_size": "hs",
        "name": "{sample}",
        "outdir": "peaks",
        "qvalue": 0.05
      },
      "shell_cmd": "macs2 callpeak -t {input[0]} -f BAMPE -g {params.genome_size} -n {params.name} --outdir {params.outdir} --nomodel --shift -100 --extsize 200 -q {params.qvalue} --keep-dup all 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/macs2/{sample}.log"
      ]
    },
    {
      "name": "peak_qc",
      "tool": "ataqv",
      "input": [
        "shifted/{sample}.shifted.bam",
        "peaks/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "qc/ataqv/{sample}.ataqv.json.gz",
        "qc/ataqv/{sample}.ataqv.out"
      ],
      "params": {
        "organism": "human",
        "tss_file": "resources/tss.bed",
        "threads": 4
      },
      "shell_cmd": "ataqv --peak-file {input[1]} --tss-file {params.tss_file} --metrics-file {output[0]} {params.organism} {input[0]} > {output[1]} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/ataqv/{sample}.log"
      ]
    },
    {
      "name": "create_bigwig",
      "tool": "deeptools",
      "input": [
        "shifted/{sample}.shifted.bam"
      ],
      "output": [
        "bigwig/{sample}.bw"
      ],
      "params": {
        "threads": 8,
        "bin_size": 10,
        "normalize_using": "RPKM",
        "effective_genome_size": 2864785220
      },
      "shell_cmd": "bamCoverage --bam {input[0]} -o {output[0]} --binSize {params.bin_size} --normalizeUsing {params.normalize_using} --effectiveGenomeSize {params.effective_genome_size} --numberOfProcessors {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 8,
        "mem_mb": 16000,
        "time_min": 90,
        "disk_mb": 20000
      },
      "log": [
        "logs/deeptools/bamCoverage/{sample}.log"
      ]
    },
    {
      "name": "motif_analysis",
      "tool": "homer",
      "input": [
        "peaks/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "motifs/{sample}/homerResults.html",
        "motifs/{sample}/knownResults.html"
      ],
      "params": {
        "genome": "hg38",
        "size": 200,
        "threads": 4,
        "outdir": "motifs/{sample}"
      },
      "shell_cmd": "findMotifsGenome.pl {input[0]} {params.genome} {params.outdir} -size {params.size} -p {params.threads} 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 180,
        "disk_mb": 20000
      },
      "log": [
        "logs/homer/{sample}.log"
      ]
    },
    {
      "name": "annotate_peaks",
      "tool": "chipseeker",
      "input": [
        "peaks/{sample}_peaks.narrowPeak"
      ],
      "output": [
        "annotation/{sample}_peak_annotation.txt",
        "annotation/{sample}_peak_annotation.pdf"
      ],
      "params": {
        "txdb": "TxDb.Hsapiens.UCSC.hg38.knownGene",
        "organism_db": "org.Hs.eg.db",
        "tss_region_start": -3000,
        "tss_region_end": 3000
      },
      "shell_cmd": "Rscript scripts/chipseeker_annotate.R {input[0]} {params.txdb} {params.organism_db} {params.tss_region_start} {params.tss_region_end} {output[0]} {output[1]} 2> {log[0]}",
      "script": "scripts/chipseeker_annotate.R",
      "resources": {
        "cpus": 4,
        "mem_mb": 16000,
        "time_min": 60,
        "disk_mb": 10000
      },
      "log": [
        "logs/chipseeker/{sample}.log"
      ]
    },
    {
      "name": "multiqc_report",
      "tool": "multiqc",
      "input": [
        "qc/fastqc/raw",
        "logs/trimmomatic",
        "logs/bowtie2",
        "qc/picard",
        "qc/ataqv",
        "bigwig",
        "motifs",
        "annotation"
      ],
      "output": [
        "qc/multiqc/multiqc_report.html",
        "qc/multiqc/multiqc_data"
      ],
      "params": {
        "outdir": "qc/multiqc",
        "dirs": "qc/fastqc/raw logs/trimmomatic logs/bowtie2 qc/picard qc/ataqv"
      },
      "shell_cmd": "multiqc {params.dirs} --outdir {params.outdir} --force 2> {log[0]}",
      "script": null,
      "resources": {
        "cpus": 2,
        "mem_mb": 8000,
        "time_min": 30,
        "disk_mb": 10000
      },
      "log": [
        "logs/multiqc/multiqc.log"
      ]
    }
  ],
  "dag_edges": [
    [
      "raw_fastqc",
      "trim_reads"
    ],
    [
      "trim_reads",
      "align_bowtie2"
    ],
    [
      "align_bowtie2",
      "filter_bam"
    ],
    [
      "filter_bam",
      "remove_duplicates"
    ],
    [
      "remove_duplicates",
      "shift_reads"
    ],
    [
      "shift_reads",
      "call_peaks"
    ],
    [
      "shift_reads",
      "create_bigwig"
    ],
    [
      "shift_reads",
      "peak_qc"
    ],
    [
      "call_peaks",
      "motif_analysis"
    ],
    [
      "call_peaks",
      "annotate_peaks"
    ],
    [
      "peak_qc",
      "multiqc_report"
    ],
    [
      "motif_analysis",
      "multiqc_report"
    ],
    [
      "annotate_peaks",
      "multiqc_report"
    ],
    [
      "create_bigwig",
      "multiqc_report"
    ]
  ],
  "config_params": {
    "samples": [
      "sample1",
      "sample2",
      "sample3"
    ],
    "paired_end": true,
    "strandedness": 0,
    "genome_build": "hg38",
    "bowtie2_index": "resources/bowtie2_index/genome",
    "nextera_adapters": "resources/NexteraPE-PE.fa",
    "tss_file": "resources/tss.bed",
    "mapq_threshold": 30,
    "macs2_genome_size": "hs",
    "macs2_qvalue": 0.05,
    "effective_genome_size": 2864785220,
    "bigwig_bin_size": 10,
    "bigwig_normalize": "RPKM",
    "motif_size": 200,
    "homer_genome": "hg38",
    "txdb": "TxDb.Hsapiens.UCSC.hg38.knownGene",
    "organism_db": "org.Hs.eg.db",
    "tss_region_start": -3000,
    "tss_region_end": 3000,
    "chrM_name": "chrM",
    "java_opts": "-Xmx16g"
  },
  "wildcards": [
    "sample"
  ]
}